@using Microsoft.JSInterop
@using PetriNetAnalyzer.Services
@using PetriNetAnalyzer.DiagramModels
@using Core.Models
@using Blazor.Diagrams.Core.Models
@using Blazor.Diagrams.Core.Models.Base
@using PetriEditor.Client.Services
@using PetriEditor.Shared.Contracts
@inject IJSRuntime JS
@inject PetriNetManager Manager
@inject SimulationService Sim
@inject DiagramStateService StateService
@inject DiagramAnalyzer Analyzer
@inject ClientAnalysisService ServerAnalysis
@inject IExportService ExportSvc
@inject DiagramSettings Settings
@inject BrowserFileService FileSvc
@implements IDisposable

<!-- ── Vertical book-tab strip ── -->
<div class="ap-strip">
    <button class="ap-book-tab @((_open && _mode == "analysis") ? "ap-book-tab--active" : "")"
            title="Analysis"
            @onclick='() => OpenMode("analysis")'>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
        </svg>
        <span>Analysis</span>
    </button>

    <button class="ap-book-tab @((_open && _mode == "simulation") ? "ap-book-tab--active" : "")"
            title="Simulation"
            @onclick='() => OpenMode("simulation")'>
        <svg viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
        <span>Simulation</span>
    </button>
</div>

@if (_open)
{
    <div id="ap-panel" class="@(_floating ? "ap-panel--floating" : "ap-panel--docked")" style="@PanelStyle">

        <!-- Title bar -->
        <div id="ap-titlebar"
             class="ap-titlebar"
             @ondblclick="ToggleFloat">
            <div class="ap-title">@(_mode == "analysis" ? "Analysis" : "Simulation")</div>
            <div class="ap-titlebar-actions">
                <button class="ap-tb-btn" title="@(_floating ? "Dock" : "Float")" @onclick="ToggleFloat">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        @if (_floating)
                        {
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <line x1="3" y1="9" x2="21" y2="9" />
                        }
                        else
                        {
                            <rect x="5" y="5" width="14" height="14" rx="2" />
                            <path d="M3 7V5a2 2 0 0 1 2-2h2" />
                            <path d="M17 3h2a2 2 0 0 1 2 2v2" />
                        }
                    </svg>
                </button>
                <button class="ap-tb-btn" title="Maximise" @onclick="Maximise">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 3 21 3 21 9" />
                        <polyline points="9 21 3 21 3 15" />
                        <line x1="21" y1="3" x2="14" y2="10" />
                        <line x1="3" y1="21" x2="10" y2="14" />
                    </svg>
                </button>
                <button class="ap-tb-btn" title="Close" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>
        </div>

        @* Analysis sub-tabs — only shown in analysis mode *@
        @if (_mode == "analysis")
        {
            <div class="ap-tabs-wrap">
                <button id="ap-tabs-arrow-left"
                        class="ap-tabs-arrow ap-tabs-arrow--left"
                        onclick="document.getElementById('ap-tabs-scroll').scrollBy({left:-120,behavior:'smooth'})">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <div id="ap-tabs-scroll" class="ap-tabs">
                    @foreach (var tab in _analysisTabs)
                    {
                        <button @onclick="() => SelectTab(tab.Id)"
                                class="ap-tab @(_activeAnalysisTab == tab.Id ? "ap-tab--active" : "")">
                            @tab.Label
                        </button>
                    }
                </div>
                <button id="ap-tabs-arrow-right"
                        class="ap-tabs-arrow ap-tabs-arrow--right"
                        onclick="document.getElementById('ap-tabs-scroll').scrollBy({left:120,behavior:'smooth'})">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        }

        <!-- Content -->
        <div style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;background:#fff;font-family:'Inter','Segoe UI',system-ui,sans-serif;">
            @if (_mode == "simulation")
            {
                <div style="flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;">
                @if (!Sim.IsActive)
                {
                    var places = Manager.Diagram.Nodes.OfType<PlaceNode>().ToList();
                    var transitions = Manager.Diagram.Nodes.OfType<TransitionNode>().ToList();
                    var arcs = Manager.Diagram.Links.OfType<PetriLinkModel>()
                    .Where(l => !l.IsDraggingEndpoint && l.Target != null).ToList();
                    var totalTokens = places.Sum(p => p.Data.Tokens);
                    var inhibArcs = arcs.Count(a => a.ArcType == ArcType.Inhibitor);
                    var resetArcs = arcs.Count(a => a.ArcType == ArcType.Reset);

                    <div style="padding:14px 14px 0;">
                        <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:8px;">Net Statistics</div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:14px;">
                            @foreach (var (label, value, color) in new[]{
                                ("Places",      places.Count.ToString(),      "#00a499"),
                                ("Transitions", transitions.Count.ToString(), "#00a499"),
                                ("Arcs",        arcs.Count.ToString(),        "#00a499"),
                                ("Tokens",      totalTokens.ToString(),       "#00a499"),
                                ("Inhibitor",   inhibArcs.ToString(),         inhibArcs>0?"#e65100":"#bbb"),
                                ("Reset",       resetArcs.ToString(),         resetArcs>0?"#6a1b9a":"#bbb"),
                                })
                            {
                                <div style="background:#f7f7f7;border:1px solid #ebebeb;border-radius:8px;padding:8px 10px;">
                                    <div style="font-size:18px;font-weight:700;color:@color;">@value</div>
                                    <div style="font-size:10px;color:#aaa;margin-top:1px;">@label</div>
                                </div>
                            }
                        </div>

                        @if (places.Any())
                        {
                            <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Initial Marking</div>
                            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px;">
                                @foreach (var p in places)
                                {
                                    <div style="display:flex;align-items:center;gap:5px;padding:4px 8px;background:#f7f7f7;border:1px solid #ebebeb;border-radius:7px;font-size:12px;">
                                        <span style="color:#888;font-weight:600;">@p.Data.Name</span>
                                        <span style="min-width:18px;text-align:center;background:@(p.Data.Tokens > 0 ? "#00a499" : "#ddd");color:@(p.Data.Tokens > 0 ? "#fff" : "#999");border-radius:10px;padding:1px 6px;font-size:11px;font-weight:700;">@p.Data.Tokens</span>
                                    </div>
                                }
                            </div>
                        }

                        @if (!places.Any() || !transitions.Any())
                        {
                            <div style="padding:8px;background:#fff8e1;border-radius:7px;font-size:11px;color:#f57f17;margin-bottom:12px;">
                                ⚠ Add places and transitions before simulating.
                            </div>
                        }

                        <button @onclick="() => Sim.Start()"
                                disabled="@(!places.Any() || !transitions.Any())"
                                style="width:100%;padding:9px 0;background:@(places.Any() && transitions.Any() ? "#00a499" : "#e0e0e0");color:@(places.Any() && transitions.Any() ? "#fff" : "#aaa");border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:@(places.Any() && transitions.Any() ? "pointer" : "default");display:flex;align-items:center;justify-content:center;gap:7px;margin-bottom:14px;">
                            <svg viewBox="0 0 24 24" fill="currentColor" style="width:13px;height:13px;"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                            Start Simulation
                        </button>
                    </div>
                }
                else
                {
                    <div style="padding:12px 14px;display:flex;flex-direction:column;gap:12px;">

                        <div style="display:flex;align-items:center;gap:6px;">
                            <div style="font-size:13px;color:#00a499;font-weight:700;flex:1;">
                                Step @Sim.StepCount
                                @if (Sim.IsViewingHistory)
                                {
                                    <span style="font-size:10px;font-weight:400;color:#f57f17;"> · viewing past</span>
                                }
                            </div>
                            @if (Sim.IsAutoFiring)
                            {
                                <div style="font-size:10px;background:#e0f5f3;color:#00a499;border-radius:10px;padding:2px 8px;font-weight:600;">● Auto</div>
                            }
                            @if (Sim.IsDeadlock)
                            {
                                <div style="font-size:10px;background:#ffebee;color:#e53935;border-radius:10px;padding:2px 8px;font-weight:600;">Deadlock</div>
                            }
                        </div>

                        <div>
                            <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Current Marking</div>
                            <div style="display:flex;flex-wrap:wrap;gap:5px;">
                                @foreach (var place in Sim.Places)
                                {
                                    var tokens = Sim.Marking.GetValueOrDefault(place.Id, 0);
                                    var initial = place.InitialTokens;
                                    var delta = tokens - initial;
                                    <div style="display:flex;align-items:center;gap:5px;padding:4px 8px;background:#f7f7f7;border:1.5px solid @(tokens > initial ? "#a5d6a7" : tokens < initial ? "#ffcdd2" : "#ebebeb");border-radius:7px;font-size:12px;">
                                        <span style="color:#888;font-weight:600;">@place.Name</span>
                                        <span style="min-width:18px;text-align:center;background:@(tokens > 0 ? "#00a499" : "#ddd");color:@(tokens > 0 ? "#fff" : "#999");border-radius:10px;padding:1px 6px;font-size:11px;font-weight:700;">@tokens</span>
                                        @if (delta != 0)
                                        {
                                            <span style="font-size:10px;color:@(delta > 0 ? "#388e3c" : "#e53935");font-weight:700;">@(delta > 0 ? "+" : "")@delta</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <div>
                            <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Fire Transition</div>
                            @{
                                var enabled = Sim.EnabledTransitions;
                            }
                            @if (Sim.IsDeadlock)
                            {
                                <div style="padding:6px 8px;background:#ffebee;border-radius:7px;font-size:11px;color:#e53935;font-weight:600;">⚠ No transitions enabled.</div>
                            }
                            else
                            {
                                <div style="display:flex;flex-direction:column;gap:3px;">
                                    @foreach (var t in Sim.Transitions.OrderByDescending(t => t.Priority))
                                    {
                                        var isEnabled = enabled.Contains(t.Id);
                                        var fired = Sim.FiringCounts.GetValueOrDefault(t.Id, 0);
                                        <button @onclick="() => Sim.StepManual(t.Id)" disabled="@(!isEnabled)"
                                                style="display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;border:1.5px solid @(isEnabled ? "#00a499" : "#ebebeb");background:@(isEnabled ? "#f0faf8" : "#fafafa");color:@(isEnabled ? "#00a499" : "#bbb");cursor:@(isEnabled ? "pointer" : "default");font-size:12px;font-weight:600;text-align:left;">
                                            <svg viewBox="0 0 24 24" fill="@(isEnabled ? "#00a499" : "#ccc")" style="width:10px;height:10px;flex-shrink:0;"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                                            @t.Name
                                            @if (t.Priority > 0)
                                            {
                                                <span style="font-size:10px;color:#aaa;">P@(t.Priority)</span>
                                            }
                                            @if (fired > 0)
                                            {
                                                <span style="margin-left:auto;font-size:10px;color:@(isEnabled ? "#80cbc4" : "#ccc");font-weight:700;">×@fired</span>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        @if (Sim.FiringCounts.Any())
                        {
                            <div>
                                <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Firing Statistics</div>
                                @{
                                    var maxFired = Sim.FiringCounts.Values.Max();
                                }
                                <div style="display:flex;flex-direction:column;gap:4px;">
                                    @foreach (var kv in Sim.FiringCounts.OrderByDescending(x => x.Value))
                                    {
                                        var tname = Sim.GetTransitionName(kv.Key);
                                        var pct = maxFired > 0 ? (int)(kv.Value * 100.0 / maxFired) : 0;
                                        <div style="font-size:12px;">
                                            <div style="display:flex;justify-content:space-between;margin-bottom:2px;">
                                                <span style="color:#555;font-weight:600;">@tname</span>
                                                <span style="color:#00a499;font-weight:700;">@kv.Value</span>
                                            </div>
                                            <div style="height:4px;background:#f0f0f0;border-radius:2px;overflow:hidden;">
                                                <div style="height:100%;width:@(pct)%;background:#00a499;border-radius:2px;transition:width 0.3s;"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div style="margin-top:6px;font-size:10px;color:#bbb;">Total firings: @Sim.StepCount</div>
                            </div>
                        }

                    </div>
                }
                </div>
            }
            else
            {
                @* ── Analysis mode content ── *@
                <div style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;">
                @{
                    bool _isGraphTab = _activeAnalysisTab == "graph";
                }
                @* Scrollable controls (hidden on graph tab) *@
                <div style="@(_isGraphTab ? "display:none;" : "flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;")">
                <div style="padding:12px 14px;display:flex;flex-direction:column;gap:10px;">

                    @* Run / Cancel button *@
                    <div style="display:flex;align-items:center;gap:6px;">
                        <button @onclick="RunAnalysis" disabled="@_analysisRunning"
                                style="flex:1;padding:8px 0;background:@(_analysisRunning ? "#f0f0f0" : "#00a499");color:@(_analysisRunning ? "#aaa" : "#fff");border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:@(_analysisRunning ? "default" : "pointer");display:flex;align-items:center;justify-content:center;gap:6px;">
                            @if (_analysisRunning)
                            {
                                <span style="display:inline-block;width:11px;height:11px;border:2px solid #aaa;border-top-color:#666;border-radius:50%;animation:spin 0.7s linear infinite;"></span>
                                <span>Running…</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="currentColor" style="width:11px;height:11px;"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                                <span>Run Analysis</span>
                            }
                        </button>
                        @if (_analysisRunning)
                        {
                            <button @onclick="CancelAnalysis"
                                    style="padding:8px 12px;background:#fff0f0;color:#e53935;border:1.5px solid #ffcdd2;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;">
                                Cancel
                            </button>
                        }
                    </div>

                    @if (_analysisRunning && _progressMessage != null)
                    {
                        <div style="display:flex;flex-direction:column;gap:4px;">
                            <div style="display:flex;justify-content:space-between;font-size:10px;color:#888;">
                                <span>@_progressMessage.Stage</span>
                                <span>@_progressMessage.Percent%</span>
                            </div>
                            <div style="height:4px;background:#e0e0e0;border-radius:2px;overflow:hidden;">
                                <div style="height:100%;width:@(_progressMessage.Percent)%;background:#00a499;border-radius:2px;transition:width 0.3s;"></div>
                            </div>
                        </div>
                    }

                    @if (_analysisError != null)
                    {
                        @if (_analysisError == "Analysis cancelled.")
                        {
                            <div style="padding:7px 10px;background:#f5f5f5;border-radius:7px;font-size:11px;color:#888;">✕ @_analysisError</div>
                        }
                        else
                        {
                            <div style="padding:7px 10px;background:#ffebee;border-radius:7px;font-size:11px;color:#c62828;">⚠ @_analysisError</div>
                        }
                    }

                    @if (_resultStale && _result is not null)
                    {
                        <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                    background:#fff3e0;border:1px solid #ffb74d;border-radius:8px;margin-bottom:6px;">
                            <span style="font-size:14px;line-height:1;">⚠</span>
                            <span style="font-size:11px;color:#5f3a00;line-height:1.5;flex:1;">
                                Net changed — results below may be outdated. Run analysis again to update.
                            </span>
                            <button @onclick="RunAnalysis"
                                    style="padding:3px 10px;font-size:10px;font-weight:700;background:#ff9800;color:#fff;
                                           border:none;border-radius:6px;cursor:pointer;white-space:nowrap;flex-shrink:0;">
                                Re-run
                            </button>
                        </div>
                    }

                    @if (_result is not null)
                    {
                        @* ── Properties tab ── *@
                        @if (!_isGraphTab && _activeAnalysisTab == "properties")
                        {
                            // Behavioural properties (always shown)
                            var behaviouralProps = new[]
                            {
                                ("Reversibility", "Reversibility"),
                                ("Liveness",      "Liveness"),
                                ("Boundedness",   "Boundedness"),
                                ("Safety",        "Safety"),
                                ("DeadlockFree",  "Deadlock-Free"),
                            };

                            // Structural properties (only meaningful for plain P/T nets)
                            var structuralProps = new[]
                            {
                                ("Conservativeness", "Conservativeness"),
                                ("Repetitiveness",   "Repetitiveness"),
                            };

                            var _ns = _result.NetStructure;
                            bool isPlainNet = _ns.InhibitorArcCount == 0 && _ns.ResetArcCount == 0;

                            var allShownProps = isPlainNet
                                ? behaviouralProps.Concat(structuralProps).ToArray()
                                : behaviouralProps;

                            var passCount        = allShownProps.Count(x => _result.PropertyResults.FirstOrDefault(r => r.Property == x.Item1)?.Status == "Pass");
                            var failCount        = allShownProps.Count(x => _result.PropertyResults.FirstOrDefault(r => r.Property == x.Item1)?.Status == "Fail");
                            var undecidableCount = allShownProps.Count(x => { var s = _result.PropertyResults.FirstOrDefault(r => r.Property == x.Item1)?.Status; return s != null && s != "Pass" && s != "Fail"; });

                            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:4px;">
                                <div style="background:#f6fbf9;border:1px solid #d9efe4;border-radius:10px;padding:10px 12px;">
                                    <div style="font-size:22px;font-weight:800;color:#2e7d32;line-height:1;">@passCount</div>
                                    <div style="font-size:11px;color:#67806f;margin-top:4px;">Passing</div>
                                </div>
                                <div style="background:#fff7f7;border:1px solid #f3d9dc;border-radius:10px;padding:10px 12px;">
                                    <div style="font-size:22px;font-weight:800;color:#c62828;line-height:1;">@failCount</div>
                                    <div style="font-size:11px;color:#8a6a6a;margin-top:4px;">Failing</div>
                                </div>
                                <div style="background:#fffaf0;border:1px solid #f2e4b8;border-radius:10px;padding:10px 12px;">
                                    <div style="font-size:22px;font-weight:800;color:#f57f17;line-height:1;">@undecidableCount</div>
                                    <div style="font-size:11px;color:#8f7d51;margin-top:4px;">Undecidable</div>
                                </div>
                            </div>

                            var shownGroups = isPlainNet
                                ? new[] { ("", behaviouralProps), ("STRUCTURAL", structuralProps) }
                                : new[] { ("", behaviouralProps) };

                            @if (!isPlainNet)
                            {
                                var _suppressedParts = new List<string>();
                                if (_ns.InhibitorArcCount > 0) _suppressedParts.Add($"{_ns.InhibitorArcCount} inhibitor arc{(_ns.InhibitorArcCount > 1 ? "s" : "")}");
                                if (_ns.ResetArcCount > 0)     _suppressedParts.Add($"{_ns.ResetArcCount} reset arc{(_ns.ResetArcCount > 1 ? "s" : "")}");
                                <div style="display:flex;gap:10px;padding:10px 12px;background:#fff8e1;border:1px solid #ffe082;border-radius:10px;margin-bottom:4px;">
                                    <span style="font-size:14px;flex-shrink:0;line-height:1.4;">⚠</span>
                                    <div style="font-size:11px;color:#5f4400;line-height:1.6;">
                                        <strong>Conservativeness</strong> and <strong>Repetitiveness</strong> are hidden —
                                        they require standard P/T firing semantics but this net has @string.Join(" and ", _suppressedParts).
                                    </div>
                                </div>
                            }

                            <div style="display:flex;flex-direction:column;gap:10px;">
                                @foreach (var (groupLabel, group) in shownGroups)
                                {
                                    @if (!string.IsNullOrEmpty(groupLabel))
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin:2px 0 0;">
                                            <div style="flex:1;height:1px;background:#e8e8e8;"></div>
                                            <span style="font-size:10px;color:#b0b8c4;font-weight:600;white-space:nowrap;">@groupLabel</span>
                                            <div style="flex:1;height:1px;background:#e8e8e8;"></div>
                                        </div>
                                    }
                                    @foreach (var (propName, label) in group)
                                    {
                                        var r = _result.PropertyResults.FirstOrDefault(pr => pr.Property == propName);
                                        var expanded = _expandedProp == propName;
                                        var hasDetails = (r?.Reasons.Count ?? 0) > 0 || (r?.Errors.Count ?? 0) > 0;
                                        <div style="border:1px solid #e6e6e6;border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 1px 2px rgba(0,0,0,0.03);">
                                            <button @onclick="() => ToggleProp(propName)"
                                                    style="width:100%;display:flex;align-items:center;gap:10px;padding:12px 14px;background:@(r?.StatusBackground ?? "#fafafa");border:none;cursor:pointer;text-align:left;">
                                                <div style="width:10px;height:10px;border-radius:50%;background:@(r?.StatusColor ?? "#bbb");flex-shrink:0;"></div>
                                                <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;">
                                                    <span style="font-size:13px;font-weight:800;color:#303030;">@label</span>
                                                    <span style="font-size:11px;color:#7a7a7a;">@GetPropertySummary(r)</span>
                                                </div>
                                                <span style="font-size:11px;font-weight:800;color:@(r?.StatusColor ?? "#888");background:#fff;padding:4px 10px;border-radius:999px;border:1px solid @(r?.StatusColor ?? "#ddd");white-space:nowrap;">@(r?.StatusLabel ?? "–")</span>
                                                <svg viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;flex-shrink:0;transform:@(expanded ? "rotate(180deg)" : "rotate(0deg)");transition:transform 0.15s;">
                                                    <polyline points="6 9 12 15 18 9" />
                                                </svg>
                                            </button>
                                            @if (expanded && r != null)
                                            {
                                                <div style="padding:12px 14px;background:#fff;border-top:1px solid #f1f1f1;display:flex;flex-direction:column;gap:12px;">
                                                    @if (r.Reasons.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:10px;font-weight:800;color:#9a9a9a;text-transform:uppercase;letter-spacing:0.7px;margin-bottom:8px;">Why</div>
                                                            <div style="display:flex;flex-direction:column;gap:7px;">
                                                                @foreach (var reason in r.Reasons)
                                                                {
                                                                    <div style="display:flex;gap:8px;align-items:flex-start;padding:8px 10px;background:#fafafa;border:1px solid #efefef;border-radius:9px;">
                                                                        <span style="color:@(r.StatusColor);font-size:12px;line-height:1.4;">•</span>
                                                                        <span style="font-size:12px;color:#4d4d4d;line-height:1.55;">@reason</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (r.Errors.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:10px;font-weight:800;color:#c62828;text-transform:uppercase;letter-spacing:0.7px;margin-bottom:8px;">Technical details</div>
                                                            <div style="display:flex;flex-direction:column;gap:7px;">
                                                                @foreach (var err in r.Errors)
                                                                {
                                                                    <div style="padding:9px 10px;background:#fff5f5;border:1px solid #f0c8c8;border-radius:9px;font-size:12px;color:#a12626;line-height:1.5;">
                                                                        ⚠ @err
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (!hasDetails)
                                                    {
                                                        <div style="font-size:12px;color:#7c7c7c;line-height:1.5;">No extra details are available for this property.</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }

                        @* ── Classification tab ── *@
                        else if (_activeAnalysisTab == "classification")
                        {
                            var ns = _result.NetStructure;
                            var subclasses = _result.ClassificationSubclasses;
                            var clsSuppressed = TabSuppressedReason("classification");
                            var clsChecks = new[]
                            {
                                ("Ordinary",           "Ordinary",             "All arcs are ordinary unit-weight arcs (weight 1, no inhibitor/reset arcs)."),
                                ("StateMachine",       "State Machine",        "Each transition has exactly one input and one output place."),
                                ("MarkedGraph",        "Marked Graph",         "Each place has exactly one input and one output transition."),
                                ("FreeChoice",         "Free Choice",          "If two transitions share an input place, they share all input places."),
                                ("ExtendedFreeChoice", "Extended Free Choice", "If two transitions share an input place, each has exactly one input place."),
                            };
                            @if (clsSuppressed == null)
                            {
                                <div style="background:#f7f7f7;border:1.5px solid #ebebeb;border-radius:9px;padding:12px;margin-bottom:8px;">
                                    <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Net Type</div>
                                    <div style="font-size:15px;font-weight:700;color:#00a499;">@_result.ClassificationSummary</div>
                                </div>
                            }

                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;">
                                @foreach (var (label, value, color) in new[]{
                                    ("Places",      ns.PlaceCount.ToString(),      "#00a499"),
                                    ("Transitions", ns.TransitionCount.ToString(), "#00a499"),
                                    ("Normal Arcs", ns.NormalArcCount.ToString(),  "#00a499"),
                                    ("Inhibitor",   ns.InhibitorArcCount.ToString(), ns.InhibitorArcCount > 0 ? "#e65100" : "#bbb"),
                                    ("Reset Arcs",  ns.ResetArcCount.ToString(),   ns.ResetArcCount > 0 ? "#6a1b9a" : "#bbb"),
                                    ("Init Tokens", ns.InitialTokenCount.ToString(), "#00a499"),
                                    })
                                {
                                    <div style="background:#f7f7f7;border:1px solid #ebebeb;border-radius:8px;padding:7px 10px;">
                                        <div style="font-size:15px;font-weight:700;color:@color;">@value</div>
                                        <div style="font-size:10px;color:#aaa;margin-top:1px;">@label</div>
                                    </div>
                                }
                            </div>

                            @if (clsSuppressed != null)
                            {
                                <div style="display:flex;gap:10px;padding:12px 14px;background:#fff8e1;border:1px solid #ffe082;border-radius:10px;">
                                    <span style="font-size:16px;flex-shrink:0;line-height:1.3;">⚠</span>
                                    <div style="font-size:12px;color:#5f4400;line-height:1.6;">@clsSuppressed</div>
                                </div>
                            }
                            else
                            {
                            <div style="display:flex;flex-direction:column;gap:5px;">
                                @foreach (var (sub, name, desc) in clsChecks)
                                {
                                    bool has = subclasses.Contains(sub);
                                    <div style="display:flex;align-items:flex-start;gap:8px;padding:7px 10px;background:@(has ? "#e8f5e9" : "#fafafa");border:1px solid @(has ? "#a5d6a7" : "#ebebeb");border-radius:7px;">
                                        <span style="font-size:14px;color:@(has ? "#2e7d32" : "#ccc");flex-shrink:0;margin-top:1px;">@(has ? "✓" : "✗")</span>
                                        <div>
                                            <div style="font-size:12px;font-weight:700;color:@(has ? "#2e7d32" : "#999");">@name</div>
                                            <div style="font-size:11px;color:#aaa;margin-top:1px;">@desc</div>
                                        </div>
                                    </div>
                                }
                            </div>
                            }
                        }

                        @* ── Cycles tab ── *@
                        else if (_activeAnalysisTab == "cycles")
                        {
                            var cycSuppressed = TabSuppressedReason("cycles");
                            @if (cycSuppressed != null)
                            {
                                <div style="display:flex;gap:10px;padding:12px 14px;background:#fff8e1;border:1px solid #ffe082;border-radius:10px;">
                                    <span style="font-size:16px;flex-shrink:0;line-height:1.3;">⚠</span>
                                    <div style="font-size:12px;color:#5f4400;line-height:1.6;">@cycSuppressed</div>
                                </div>
                            }
                            else
                            {
                            var cyc = _result.Cycles;
                            @if (cyc == null || cyc.HasErrors)
                            {
                                <div style="font-size:12px;color:#e53935;">@(cyc?.ErrorMsg ?? "Cycle analysis not available.")</div>
                            }
                            else
                            {
                                var nameById = BuildNameById();
                                string Resolve(string id) => nameById.GetValueOrDefault(id, id);
                                var ns2 = _result.NetStructure;
                                <div style="display:flex;flex-direction:column;gap:14px;">
                                    <div style="background:#fff;border:1px solid #e3e3e3;box-shadow:0 2px 8px rgba(0,0,0,0.06);padding:18px 18px 16px;">
                                        <div style="font-size:14px;font-weight:800;color:#00a499;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #e5e5e5;">Net cycle coverage</div>
                                        <div style="display:flex;flex-direction:column;gap:12px;color:#666;font-size:12px;line-height:1.55;">
                                            <div>
                                                @if (cyc.PlaceCoverage == ns2.PlaceCount)
                                                {
                                                    <span>Each place belongs to some elementary cycle carrier</span>
                                                }
                                                else
                                                {
                                                    <span>@cyc.PlaceCoverage of @ns2.PlaceCount place(s) belong to some elementary cycle carrier</span>
                                                }
                                            </div>
                                            <div>
                                                @if (cyc.TransitionCoverage == ns2.TransitionCount)
                                                {
                                                    <span>Each transition belongs to some elementary cycle carrier</span>
                                                }
                                                else
                                                {
                                                    <span>@cyc.TransitionCoverage of @ns2.TransitionCount transition(s) belong to some elementary cycle carrier</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div style="background:#fff;border:1px solid #e3e3e3;box-shadow:0 2px 8px rgba(0,0,0,0.06);padding:18px 18px 16px;">
                                        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #e5e5e5;">
                                            <div style="font-size:14px;font-weight:800;color:#00a499;">Elementary cycles</div>
                                            <div style="font-size:11px;color:#8b8b8b;">@cyc.Cycles.Count cycle(s)</div>
                                        </div>

                                        @if (!cyc.Cycles.Any())
                                        {
                                            <div style="font-size:12px;color:#999;line-height:1.6;">No cycles found in this net.</div>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-direction:column;gap:12px;">
                                                @for (int ci = 0; ci < cyc.Cycles.Count; ci++)
                                                {
                                                    var cycle = cyc.Cycles[ci];
                                                    var cycleNodes = cycle.NodeIds.Select(id => Resolve(id)).ToList();
                                                    if (cycleNodes.Count > 0) cycleNodes.Add(cycleNodes[0]);
                                                    var cycleMarkup = string.Join(" → ", cycleNodes);
                                                    var cycleKey = $"cycle_{ci}";
                                                    var cycleActive = _highlightedItemKey == cycleKey;
                                                    var cycleEyeLit = cycleActive || _hoverItemKey == cycleKey;
                                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                                                        <div style="font-size:12px;color:#666;line-height:1.7;min-width:0;flex:1;">
                                                            <span style="font-weight:700;color:#666;">C<sub>@(ci + 1)</sub></span>
                                                            <span> = @cycleMarkup</span>
                                                        </div>
                                                        <div style="display:flex;align-items:center;gap:6px;white-space:nowrap;flex-shrink:0;">
                                                            <span style="font-size:11px;color:@(cycle.TokensInCycle > 0 ? "#2e7d32" : "#9a9a9a");font-weight:600;">@cycle.TokensInCycle token(s)</span>
                                                            <button title="@(cycleActive ? "Clear highlight" : "Highlight in net")"
                                                                    @onclick='() => ToggleHighlight(cycleKey, cycle.NodeIds)'
                                                                    @onmouseenter='() => OnEyeHoverEnter(cycleKey, cycle.NodeIds)'
                                                                    @onmouseleave='OnEyeHoverLeave'
                                                                    style="padding:2px 5px;border:1px solid @(cycleEyeLit ? "#7c3aed" : "#ddd");border-radius:5px;background:@(cycleActive ? "#f5f3ff" : cycleEyeLit ? "#faf5ff" : "#fafafa");color:@(cycleEyeLit ? "#7c3aed" : "#aaa");cursor:pointer;font-size:13px;line-height:1;">
                                                                👁
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            }
                        }

                        @* ── Invariant tab ── *@
                        else if (_activeAnalysisTab == "invariant")
                        {
                            var invSuppressed = TabSuppressedReason("invariant");
                            @if (invSuppressed != null)
                            {
                                <div style="display:flex;gap:10px;padding:12px 14px;background:#fff8e1;border:1px solid #ffe082;border-radius:10px;">
                                    <span style="font-size:16px;flex-shrink:0;line-height:1.3;">⚠</span>
                                    <div style="font-size:12px;color:#5f4400;line-height:1.6;">@invSuppressed</div>
                                </div>
                            }
                            else
                            {
                            var nameById2 = BuildNameById();
                            string Resolve2(string id) => nameById2.GetValueOrDefault(id, id);

                            string FormatInvariant(InvariantDto inv)
                            {
                                var parts = inv.Structure.Select(kv => kv.Value == 1
                                    ? Resolve2(kv.Key)
                                    : $"{kv.Value}{Resolve2(kv.Key)}");
                                return $"({string.Join(", ", parts)})";
                            }

                            int ComputePInvariantConstant(InvariantDto inv)
                            {
                                var total = 0;
                                if (_lastDto != null)
                                {
                                    foreach (var kv in inv.Structure)
                                    {
                                        var pl = _lastDto.Places.FirstOrDefault(p => p.Id == kv.Key);
                                        if (pl != null) total += kv.Value * pl.Tokens;
                                    }
                                }
                                return total;
                            }

                            // Transitions that actually fired in the (possibly truncated) state space
                            var _firedTransIds = _result.ReachabilityGraph?.Edges
                                .Select(e => e.TransitionId).ToHashSet()
                                ?? new HashSet<string>();
                            bool _ssAvailable = _result.ReachabilityGraph != null;

                            @if (!_result.PInvariants.Any() && !_result.TInvariants.Any())
                            {
                                <div style="font-size:12px;color:#e53935;">Invariant analysis not available.</div>
                            }
                            else
                            {
                                @if (_result.InvariantsTruncated)
                                {
                                    <div style="font-size:11px;color:#b26a00;background:#fff8e6;border:1px solid #ffe0a3;border-radius:6px;padding:8px 10px;margin-bottom:10px;line-height:1.5;">
                                        ⚠ Candidate set exceeded @Analysis.Engines.InvariantAnalysis.MaxCandidates during Farkas elimination — the list below may be incomplete.
                                    </div>
                                }
                                <div style="display:flex;flex-direction:column;gap:14px;">
                                    <div style="background:#fff;border:1px solid #e3e3e3;box-shadow:0 2px 8px rgba(0,0,0,0.06);padding:18px 18px 16px;">
                                        <div style="font-size:14px;font-weight:800;color:#00a499;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #e5e5e5;">P - invariants</div>
                                        @if (!_result.PInvariants.Any())
                                        {
                                            <div style="font-size:12px;color:#999;line-height:1.6;">No P-invariants found.</div>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-direction:column;gap:12px;">
                                                @for (int i = 0; i < _result.PInvariants.Count; i++)
                                                {
                                                    var pInv = _result.PInvariants[i];
                                                    var pInvKey = $"pinv_{i}";
                                                    var pInvActive = _highlightedItemKey == pInvKey;
                                                    var pInvEyeLit = pInvActive || _hoverItemKey == pInvKey;
                                                    <div style="position:relative;">
                                                        <div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:18px;align-items:start;">
                                                            <div>
                                                                <div style="font-size:12px;font-weight:700;color:#666;margin-bottom:6px;">Structural</div>
                                                                <div style="font-size:12px;color:#666;line-height:1.7;">
                                                                    <span>Y<sup>T</sup><sub>@(i + 1)</sub> = @FormatInvariant(pInv)</span>
                                                                </div>
                                                            </div>
                                                            <div style="border-left:1px solid #e1e1e1;padding-left:18px;">
                                                                <div style="font-size:12px;font-weight:700;color:#666;margin-bottom:6px;">System</div>
                                                                <div style="font-size:12px;color:#666;line-height:1.7;">
                                                                    <span>Y<sup>T</sup><sub>@(i + 1)</sub> · M<sup>0</sup> = @ComputePInvariantConstant(pInv)</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <button title="@(pInvActive ? "Clear highlight" : "Highlight places in net")"
                                                                @onclick='() => ToggleHighlight(pInvKey, pInv.Structure.Keys)'
                                                                @onmouseenter='() => OnEyeHoverEnter(pInvKey, pInv.Structure.Keys)'
                                                                @onmouseleave='OnEyeHoverLeave'
                                                                style="position:absolute;top:0;right:0;padding:2px 5px;border:1px solid @(pInvEyeLit ? "#7c3aed" : "#ddd");border-radius:5px;background:@(pInvActive ? "#f5f3ff" : pInvEyeLit ? "#faf5ff" : "#fafafa");color:@(pInvEyeLit ? "#7c3aed" : "#aaa");cursor:pointer;font-size:13px;line-height:1;">
                                                            👁
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div style="background:#fff;border:1px solid #e3e3e3;box-shadow:0 2px 8px rgba(0,0,0,0.06);padding:18px 18px 16px;">
                                        <div style="font-size:14px;font-weight:800;color:#00a499;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #e5e5e5;">T - invariants</div>
                                        @if (!_result.TInvariants.Any())
                                        {
                                            <div style="font-size:12px;color:#999;line-height:1.6;">No T-invariants found.</div>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-direction:column;gap:12px;">
                                                @for (int i = 0; i < _result.TInvariants.Count; i++)
                                                {
                                                    var tInv = _result.TInvariants[i];
                                                    var tInvKey = $"tinv_{i}";
                                                    var tInvActive = _highlightedItemKey == tInvKey;
                                                    var tInvEyeLit = tInvActive || _hoverItemKey == tInvKey;
                                                    <div style="position:relative;">
                                                        <div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:18px;align-items:start;">
                                                            <div>
                                                                <div style="font-size:12px;font-weight:700;color:#666;margin-bottom:6px;">Structural</div>
                                                                <div style="font-size:12px;color:#666;line-height:1.7;">
                                                                    <span>X<sup>T</sup><sub>@(i + 1)</sub> = @FormatInvariant(tInv)</span>
                                                                </div>
                                                            </div>
                                                            <div style="border-left:1px solid #e1e1e1;padding-left:18px;">
                                                                <div style="font-size:12px;font-weight:700;color:#666;margin-bottom:6px;">System</div>
                                                                <div style="font-size:12px;color:#666;line-height:1.7;">
                                                                    @{
                                                                        // Order transitions by their position in the net definition,
                                                                        // expand each by its coefficient (firing count)
                                                                        var _tSeq = (_lastDto?.Transitions ?? [])
                                                                            .Where(t => tInv.Structure.ContainsKey(t.Id))
                                                                            .SelectMany(t => Enumerable.Repeat(Resolve2(t.Id), tInv.Structure[t.Id]))
                                                                            .ToList();
                                                                        if (_tSeq.Count == 0)
                                                                            _tSeq = tInv.Structure
                                                                                .SelectMany(kv => Enumerable.Repeat(Resolve2(kv.Key), kv.Value))
                                                                                .ToList();
                                                                        var _notFired2 = _ssAvailable
                                                                            ? tInv.Structure.Keys.Where(id => !_firedTransIds.Contains(id)).ToHashSet()
                                                                            : new HashSet<string>();
                                                                    }
                                                                    <span>σ<sub>@(i + 1)</sub> = @string.Join(", ", _tSeq)</span>
                                                                    @if (_ssAvailable && _notFired2.Count > 0)
                                                                    {
                                                                        <span title="@string.Join(", ", _notFired2.Select(Resolve2)) not observed in state space" style="color:#bf360c;margin-left:4px;">⚠</span>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <button title="@(tInvActive ? "Clear highlight" : "Highlight transitions in net")"
                                                                @onclick='() => ToggleHighlight(tInvKey, tInv.Structure.Keys)'
                                                                @onmouseenter='() => OnEyeHoverEnter(tInvKey, tInv.Structure.Keys)'
                                                                @onmouseleave='OnEyeHoverLeave'
                                                                style="position:absolute;top:0;right:0;padding:2px 5px;border:1px solid @(tInvEyeLit ? "#7c3aed" : "#ddd");border-radius:5px;background:@(tInvActive ? "#f5f3ff" : tInvEyeLit ? "#faf5ff" : "#fafafa");color:@(tInvEyeLit ? "#7c3aed" : "#aaa");cursor:pointer;font-size:13px;line-height:1;">
                                                            👁
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            }
                        }

                        @* ── Traps tab ── *@
                        else if (_activeAnalysisTab == "traps")
                        {
                            var trapsSuppressed = TabSuppressedReason("traps");
                            @if (trapsSuppressed != null)
                            {
                                <div style="display:flex;gap:10px;padding:12px 14px;background:#fff8e1;border:1px solid #ffe082;border-radius:10px;">
                                    <span style="font-size:16px;flex-shrink:0;line-height:1.3;">⚠</span>
                                    <div style="font-size:12px;color:#5f4400;line-height:1.6;">@trapsSuppressed</div>
                                </div>
                            }
                            else
                            {
                            var tc = _result.Traps;
                            @if (tc == null || tc.HasErrors)
                            {
                                <div style="font-size:12px;color:#e53935;">@(tc?.ErrorMsg ?? "Trap/co-trap analysis not available.")</div>
                            }
                            else
                            {
                                var nameById3 = BuildNameById();
                                string Resolve3(string id) => nameById3.GetValueOrDefault(id, id);
                                <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:4px;">Traps (@tc.Traps.Count)</div>
                                @if (!tc.Traps.Any())
                                {
                                    <div style="font-size:12px;color:#aaa;margin-bottom:10px;">None found.</div>
                                }
                                @for (int ti = 0; ti < tc.Traps.Count; ti++)
                                {
                                    var trap = tc.Traps[ti];
                                    var trapKey = $"trap_{ti}";
                                    var trapActive = _highlightedItemKey == trapKey;
                                    var trapEyeLit = trapActive || _hoverItemKey == trapKey;
                                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;">
                                        <div style="flex:1;padding:5px 8px;background:@(trap.HasToken ? "#e8f5e9" : "#fafafa");border:1px solid @(trap.HasToken ? "#a5d6a7" : "#ebebeb");border-radius:6px;font-size:11px;color:#555;">
                                            { @string.Join(", ", trap.PlaceIds.Select(id => Resolve3(id))) }
                                            @if (trap.HasToken)
                                            {
                                                <span style="color:#2e7d32;font-weight:700;"> ● marked</span>
                                            }
                                        </div>
                                        <button title="@(trapActive ? "Clear highlight" : "Highlight in net")"
                                                @onclick='() => ToggleHighlight(trapKey, trap.PlaceIds)'
                                                @onmouseenter='() => OnEyeHoverEnter(trapKey, trap.PlaceIds)'
                                                @onmouseleave='OnEyeHoverLeave'
                                                style="padding:2px 5px;border:1px solid @(trapEyeLit ? "#7c3aed" : "#ddd");border-radius:5px;background:@(trapActive ? "#f5f3ff" : trapEyeLit ? "#faf5ff" : "#fafafa");color:@(trapEyeLit ? "#7c3aed" : "#aaa");cursor:pointer;font-size:13px;line-height:1;flex-shrink:0;">
                                            👁
                                        </button>
                                    </div>
                                }
                                <div style="font-size:10px;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:0.6px;margin:8px 0 4px;">Siphons / Co-traps (@tc.Siphons.Count)</div>
                                @if (!tc.Siphons.Any())
                                {
                                    <div style="font-size:12px;color:#aaa;">None found.</div>
                                }
                                @for (int si = 0; si < tc.Siphons.Count; si++)
                                {
                                    var siphon = tc.Siphons[si];
                                    var siphonPlaceSet = new HashSet<string>(siphon.PlaceIds);
                                    var isDangerous = !tc.Traps.Any(trap => trap.HasToken && trap.PlaceIds.All(pid => siphonPlaceSet.Contains(pid)));
                                    var siphonKey = $"siphon_{si}";
                                    var siphonActive = _highlightedItemKey == siphonKey;
                                    var siphonEyeLit = siphonActive || _hoverItemKey == siphonKey;
                                    <div style="display:flex;align-items:flex-start;gap:6px;margin-bottom:3px;">
                                        <div style="flex:1;padding:5px 8px;background:@(isDangerous ? "#fff3e0" : "#fafafa");border:1px solid @(isDangerous ? "#ffb74d" : "#ebebeb");border-radius:6px;font-size:11px;color:#555;">
                                            { @string.Join(", ", siphon.PlaceIds.Select(id => Resolve3(id))) }
                                            @if (isDangerous)
                                            {
                                                <span style="color:#e65100;font-weight:700;"> ⚠ no marked trap inside this siphon/co-trap</span>
                                            }
                                            @if (isDangerous)
                                            {
                                                <div style="margin-top:4px;color:#9a6a00;font-size:10px;line-height:1.5;">This means the set does not currently contain any trap that already has a token. If this siphon/co-trap becomes empty, the net may not be able to mark it again.</div>
                                            }
                                        </div>
                                        <button title="@(siphonActive ? "Clear highlight" : "Highlight in net")"
                                                @onclick='() => ToggleHighlight(siphonKey, siphon.PlaceIds)'
                                                @onmouseenter='() => OnEyeHoverEnter(siphonKey, siphon.PlaceIds)'
                                                @onmouseleave='OnEyeHoverLeave'
                                                style="padding:2px 5px;border:1px solid @(siphonEyeLit ? "#7c3aed" : "#ddd");border-radius:5px;background:@(siphonActive ? "#f5f3ff" : siphonEyeLit ? "#faf5ff" : "#fafafa");color:@(siphonEyeLit ? "#7c3aed" : "#aaa");cursor:pointer;font-size:13px;line-height:1;flex-shrink:0;margin-top:3px;">
                                            👁
                                        </button>
                                    </div>
                                }
                            }
                            }
                        }
                    }
                    else if (!_analysisRunning)
                    {
                        <p style="font-size:12px;color:#bbb;text-align:center;padding:20px 0;">Press Run Analysis to compute results.</p>
                    }

                </div>
                </div>@* end scrollable controls *@

                @* ── Graph / Tree tab ── *@
                <GraphTreePanel @ref="_refGraphTree"
                                IsVisible="@(_activeAnalysisTab == "graph")"
                                ResultStale="@_resultStale"
                                NetVersion="@_netVersion"
                                AnalysisResult="@_result" />


                @* CSS for spinner *@
                <style>
                    @@keyframes spin {
                        to {
                            transform: rotate(360deg);
                        }
                    }
                </style>
                </div>@* end analysis flex column *@
            }
        </div>

        <!-- Resize handles -->
        @if (!_floating)
        {
            <div id="ap-resize-left" style="position:absolute;left:0;top:0;width:5px;height:100%;cursor:ew-resize;z-index:10;"></div>
        }
        else
        {
            <div id="ap-resize-w" style="position:absolute;left:0;top:6px;width:5px;height:calc(100% - 12px);cursor:ew-resize;z-index:10;"></div>
            <div id="ap-resize-e" style="position:absolute;right:0;top:6px;width:5px;height:calc(100% - 12px);cursor:ew-resize;z-index:10;"></div>
            <div id="ap-resize-n" style="position:absolute;top:0;left:6px;height:5px;width:calc(100% - 12px);cursor:ns-resize;z-index:10;"></div>
            <div id="ap-resize-s" style="position:absolute;bottom:0;left:6px;height:5px;width:calc(100% - 12px);cursor:ns-resize;z-index:10;"></div>
            <div id="ap-resize-nw" style="position:absolute;top:0;left:0;width:10px;height:10px;cursor:nw-resize;z-index:10;"></div>
            <div id="ap-resize-ne" style="position:absolute;top:0;right:0;width:10px;height:10px;cursor:ne-resize;z-index:10;"></div>
            <div id="ap-resize-sw" style="position:absolute;bottom:0;left:0;width:10px;height:10px;cursor:sw-resize;z-index:10;"></div>
            <div id="ap-resize-se" style="position:absolute;bottom:0;right:0;width:10px;height:10px;cursor:se-resize;z-index:10;"></div>
        }
    </div>
}

@* ── Export modal — rendered at component root so it works regardless of panel open state ── *@
@if (_exportModalOpen)
{
    <div @onclick="() => _exportModalOpen = false"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:1000;display:flex;align-items:center;justify-content:center;">
        <div @onclick:stopPropagation
             style="background:#fff;border-radius:12px;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:360px;max-width:95vw;padding:20px 22px;display:flex;flex-direction:column;gap:14px;font-family:Inter,sans-serif;">

            @* Title row *@
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:14px;font-weight:700;color:#111827;">Export</span>
                <button @onclick="() => _exportModalOpen = false"
                        style="background:none;border:none;font-size:18px;color:#9aa0ad;cursor:pointer;line-height:1;padding:0 2px;">×</button>
            </div>

            @* ── Format tabs ── *@
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px;">
                @foreach (var (fmt, label, desc) in ExportFormatOptions)
                {
                    <button @onclick="() => _expFormat = fmt"
                            style="padding:7px 4px;border-radius:8px;border:1.5px solid @(_expFormat == fmt ? "#00a499" : "#e4e6ea");
                                   background:@(_expFormat == fmt ? "#e8f5f3" : "#fafafa");
                                   color:@(_expFormat == fmt ? "#00796b" : "#6b7280");
                                   font-size:12px;font-weight:@(_expFormat == fmt ? "700" : "500");cursor:pointer;text-align:center;">
                        @label
                    </button>
                }
            </div>

            @* ── Format description + options ── *@
            @if (_expFormat == "pdf")
            {
                <div style="display:flex;flex-direction:column;gap:5px;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:#9aa0ad;margin-bottom:2px;">Include in PDF</div>

                    <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:#374151;cursor:pointer;">
                        <input type="checkbox" checked="@_expIncludeDiagram" @onchange="e => _expIncludeDiagram = (bool)(e.Value ?? true)" style="accent-color:#00a499;" />
                        Net diagram (visual)
                    </label>

                    <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:#374151;cursor:pointer;">
                        <input type="checkbox" checked="@_expIncludeStructure" @onchange="e => _expIncludeStructure = (bool)(e.Value ?? true)" style="accent-color:#00a499;" />
                        Net structure (places, transitions, arcs)
                    </label>

                    <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:#374151;cursor:pointer;">
                        <input type="checkbox" checked="@_expIncludeAnalysis" @onchange="e => _expIncludeAnalysis = (bool)(e.Value ?? true)" style="accent-color:#00a499;" />
                        Analysis results
                        @if (_result == null)
                        {
                            <span style="font-size:10px;color:#9aa0ad;">(will run automatically)</span>
                        }
                    </label>

                    <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:#374151;cursor:pointer;">
                        <input type="checkbox" checked="@_expIncludeTree" @onchange="e => _expIncludeTree = (bool)(e.Value ?? true)" style="accent-color:#00a499;" />
                        Reachability/coverability tree
                        @if (_refGraphTree?.GraphData == null)
                        {
                            <span style="font-size:10px;color:#9aa0ad;">(will compute automatically)</span>
                        }
                    </label>
                </div>
            }
            else
            {
                <div style="padding:8px 10px;background:#f7f8fa;border-radius:8px;font-size:12px;color:#6b7280;line-height:1.5;">
                    @if (_expFormat == "svg")
                    {
                        <span>Exports the current net diagram as a scalable vector image.</span>
                    }
                    else if (_expFormat == "tikz")
                    {
                        <span>Exports the net structure as LaTeX/TikZ source. Open in any LaTeX editor.</span>
                    }
                    else if (_expFormat == "pnml")
                    {
                        <span>Exports the net as PNML (Petri Net Markup Language) — a standard XML format.</span>
                    }
                </div>
            }

            @* ── Progress / status ── *@
            @if (_exportRunning && _exportStatus != null)
            {
                <div style="font-size:11px;color:#00796b;display:flex;align-items:center;gap:7px;">
                    <span style="display:inline-block;width:11px;height:11px;border:2px solid #b2dfdb;border-top-color:#00a499;border-radius:50%;animation:spin 0.7s linear infinite;flex-shrink:0;"></span>
                    @_exportStatus
                </div>
            }

            @* ── Error ── *@
            @if (_exportError != null)
            {
                <div style="padding:6px 8px;background:#ffebee;border-radius:6px;font-size:11px;color:#c62828;">⚠ @_exportError</div>
            }

            @* ── Actions ── *@
            <div style="display:flex;gap:8px;justify-content:flex-end;padding-top:4px;border-top:1px solid #f0f0f0;">
                <button @onclick="() => _exportModalOpen = false" disabled="@_exportRunning"
                        style="padding:6px 14px;font-size:12px;font-weight:600;border:1px solid #e0e0e0;border-radius:7px;background:#fff;color:#666;cursor:@(_exportRunning ? "default" : "pointer");opacity:@(_exportRunning ? "0.5" : "1");">
                    Cancel
                </button>
                <button @onclick="RunExportAsync" disabled="@_exportRunning"
                        style="padding:6px 16px;font-size:12px;font-weight:700;border:none;border-radius:7px;
                               background:@(_exportRunning ? "#e0e0e0" : "#00a499");color:@(_exportRunning ? "#aaa" : "#fff");
                               cursor:@(_exportRunning ? "default" : "pointer");display:flex;align-items:center;gap:6px;">
                    @if (_exportRunning)
                    {
                        <span style="display:inline-block;width:11px;height:11px;border:2px solid #bbb;border-top-color:#888;border-radius:50%;animation:spin 0.7s linear infinite;"></span>
                    }
                    Export
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _open = false;
    private bool _floating = false;
    private string _mode = "simulation";  // "analysis" | "simulation"
    private string _activeAnalysisTab = "properties";

    private void SelectTab(string id)
    {
        if (_activeAnalysisTab == "graph" && id != "graph")
            _refGraphTree?.Reset();
        _activeAnalysisTab = id;
        if (id == "graph") _refGraphTree?.TryPopulateFromCache();
        _highlightedItemKey = null;
        _highlightedItemIds = null;
        _hoverItemKey = null;
        StateService.ClearHighlight();
        StateHasChanged();
    }

    private double _dockedWidth = 320;
    private const double DockedMin = 200, DockedMax = 700;
    private double _floatX = 100, _floatY = 80, _floatW = 420, _floatH = 520;
    private const double FloatMinW = 280, FloatMinH = 200;

    private record TabDef(string Id, string Label, string Description);

    // All tabs, always shown regardless of net type.
    // Inapplicable tabs display a suppressed-note instead of results.
    private static readonly TabDef[] _allTabs =
    [
        new("properties",     "Properties",     "Check liveness, boundedness, safeness and reversibility."),
        new("classification", "Classification", "Classify the net type: free-choice, state machine, etc."),
        new("cycles",         "Cycles",         "Detect cycles and siphons in the net structure."),
        new("invariant",      "Invariant",      "Compute P-invariants and T-invariants."),
        new("graph",          "Graph / Tree",   "Interactive reachability graph, coverability tree, or state space summary."),
        new("traps",          "Traps & Co-traps","Find traps, siphons and co-traps in the net."),
    ];

    private IEnumerable<TabDef> _analysisTabs => _allTabs;

    // Returns null if the tab is fully applicable, or an explanation string if it is suppressed.
    private string? TabSuppressedReason(string tabId)
    {
        if (_result is null) return null;
        var ns = _result.NetStructure;
        bool hasInhibitor = ns.InhibitorArcCount > 0;
        bool hasReset     = ns.ResetArcCount > 0;
        bool isOrdinary   = !hasInhibitor && !hasReset;
        if (isOrdinary) return null;

        var parts = new List<string>();
        if (hasInhibitor) parts.Add($"{ns.InhibitorArcCount} inhibitor arc{(ns.InhibitorArcCount > 1 ? "s" : "")}");
        if (hasReset)     parts.Add($"{ns.ResetArcCount} reset arc{(ns.ResetArcCount > 1 ? "s" : "")}");
        string arcDesc = string.Join(" and ", parts);

        return tabId switch
        {
            "invariant" =>
                $"P- and T-invariants are based on the state equation Y·C = 0, which assumes standard " +
                $"firing semantics. This net has {arcDesc}, which break the token-conservation " +
                $"assumption — results are hidden because they are not guaranteed to be correct.",
            "traps" =>
                $"Trap and siphon theory is defined for ordinary Petri nets. This net has {arcDesc} — " +
                $"the structural results may not reflect the actual reachable behaviour and are hidden.",
            "cycles" =>
                $"Elementary-cycle coverage is a purely structural measure assuming standard P/T " +
                $"semantics. This net has {arcDesc}, which invalidate that assumption — results are hidden.",
            "classification" =>
                $"Subclass checks (State Machine, Marked Graph, Free Choice) are defined for ordinary " +
                $"Petri nets only. This net has {arcDesc} — subclass results are hidden.",
            _ => null
        };
    }

    // ── Analysis state ────────────────────────────────────────────────────
    private AnalysisResultDto? _result;
    private PetriNetDto? _lastDto;
    private bool _analysisRunning = false;
    private int  _netVersion      = 0;   // increments on every structural change
    private int  _analyzedVersion = -1;  // value of _netVersion when last analysis ran
    private bool _resultStale => _result != null && _analyzedVersion != _netVersion;
    private string? _analysisError;
    private string? _expandedProp;
    private CancellationTokenSource? _analysisCts;
    private AnalysisProgressMessage? _progressMessage;

    // ── Highlight state ────────────────────────────────────────────────────
    private string?   _highlightedItemKey;   // pinned (click) highlight key
    private string[]? _highlightedItemIds;   // node IDs for the pinned item
    private string?   _hoverItemKey;         // transient (hover) key

    private void ToggleHighlight(string key, IEnumerable<string> nodeIds)
    {
        _hoverItemKey = null;
        if (_highlightedItemKey == key)
        {
            _highlightedItemKey = null;
            _highlightedItemIds = null;
            StateService.ClearHighlight();
        }
        else
        {
            var ids = nodeIds.ToArray();
            _highlightedItemKey = key;
            _highlightedItemIds = ids;
            StateService.SetHighlight(ids);
        }
    }

    private void OnEyeHoverEnter(string key, IEnumerable<string> nodeIds)
    {
        _hoverItemKey = key;
        StateService.SetHighlight(nodeIds);
    }

    private void OnEyeHoverLeave()
    {
        _hoverItemKey = null;
        // Restore pinned highlight, or clear if nothing is pinned
        if (_highlightedItemIds != null)
            StateService.SetHighlight(_highlightedItemIds);
        else
            StateService.ClearHighlight();
    }

    // ── Export state ──────────────────────────────────────────────────────
    private bool    _exportRunning    = false;
    private bool    _exportModalOpen  = false;
    private string? _exportError;
    private string? _exportStatus;

    // Modal selections
    private bool        _expIncludeDiagram   = true;
    private bool        _expIncludeStructure = true;
    private bool        _expIncludeAnalysis  = true;
    private bool        _expIncludeTree      = true;
    private string      _expFormat           = "pdf";

    public void OpenExportModal() { _exportModalOpen = true; _exportError = null; InvokeAsync(StateHasChanged); }

    private static readonly (string fmt, string label, string desc)[] ExportFormatOptions =
    [
        ("pdf",  "PDF",  ""),
        ("svg",  "SVG",  ""),
        ("tikz", "TikZ", ""),
        ("pnml", "PNML", ""),
    ];

    // Stable JS interop reference — created once, disposed in Dispose()
    private DotNetObjectReference<AnalysisPanel>? _dotNetRef;

    private void OpenMode(string mode)
    {
        if (_mode == mode && _open)
        {
            _open = false;
            return;
        }

        if (_mode == "simulation" && mode == "analysis" && Sim.IsActive)
            Sim.Stop();

        _mode = mode;
        _open = true;
        _ = SetupJsAsync();
    }

    private void ToggleProp(string prop)
        => _expandedProp = _expandedProp == prop ? null : prop;

    private static string GetPropertySummary(PropertyResultDto? r)
    {
        if (r is null) return "No result yet.";
        if (r.Reasons.Count > 0) return $"{r.Reasons.Count} note(s).";
        if (r.Errors.Count > 0) return "This result is unavailable because the algorithm hit an internal error.";
        return r.Status switch
        {
            "Pass" => "No issues detected.",
            "Fail" => "This property does not hold.",
            _ => "The result could not be decided."
        };
    }

    private object[] BuildDiagramNodeData(
        System.Collections.Generic.List<PlaceNode> places,
        System.Collections.Generic.List<TransitionNode> transitions)
    {
        var list = new System.Collections.Generic.List<object>();
        foreach (var p in places)
        {
            if (p.Position == null) continue;
            list.Add(new {
                type     = "place",
                x        = p.Position.X,
                y        = p.Position.Y,
                w        = p.Size?.Width  ?? 60,
                h        = p.Size?.Height ?? 60,
                label    = p.Data.Name,
                tokens   = p.Data.Tokens,
                arcColor = Settings.ArcColor,
            });
        }
        foreach (var t in transitions)
        {
            if (t.Position == null) continue;
            list.Add(new {
                type     = "transition",
                x        = t.Position.X,
                y        = t.Position.Y,
                w        = t.Size?.Width  ?? 36,
                h        = t.Size?.Height ?? 72,
                label    = t.Data.Name,
                tokens   = 0,
                arcColor = Settings.ArcColor,
            });
        }
        return list.ToArray();
    }

    private Dictionary<string, string> BuildNameById()
    {
        var dict = new Dictionary<string, string>();
        if (_lastDto is null) return dict;
        foreach (var p in _lastDto.Places)
            dict[p.Id] = p.Name;
        foreach (var t in _lastDto.Transitions)
            dict[t.Id] = t.Name;
        return dict;
    }

    private async Task RunExportAsync()
    {
        if (_exportRunning) return;
        _exportRunning = true;
        _exportError   = null;
        _exportStatus  = null;
        StateHasChanged();
        try
        {
            var places      = Manager.Diagram.Nodes.OfType<PlaceNode>().ToList();
            var transitions = Manager.Diagram.Nodes.OfType<TransitionNode>().ToList();
            var arcs        = Manager.Diagram.Links.OfType<PetriLinkModel>().ToList();
            var dto         = DiagramAnalyzer.BuildDto(places, transitions, arcs);

            switch (_expFormat)
            {
                case "tikz":
                {
                    var bytes = await ExportSvc.ExportAsync(new ExportRequestDto(dto, ExportFormat.TikZ, new ExportOptions()));
                    await FileSvc.DownloadAsync("petri.tex", bytes, "text/plain");
                    break;
                }
                case "pnml":
                {
                    var bytes = await ExportSvc.ExportAsync(new ExportRequestDto(dto, ExportFormat.Pnml, new ExportOptions()));
                    await FileSvc.DownloadAsync("petri.pnml", bytes, "application/xml");
                    break;
                }
                case "svg":
                {
                    _exportStatus = "Capturing diagram…"; StateHasChanged();
                    var svg = await JS.InvokeAsync<string?>("petriEditor.exportDiagramSvg");
                    if (!string.IsNullOrEmpty(svg))
                        await FileSvc.DownloadAsync("petri-net.svg",
                            System.Text.Encoding.UTF8.GetBytes(svg), "image/svg+xml");
                    break;
                }
                case "pdf":
                default:
                {
                    byte[]? diagramPng = null;
                    if (_expIncludeDiagram)
                    {
                        _exportStatus = "Capturing diagram…"; StateHasChanged();
                        var nodeData = BuildDiagramNodeData(places, transitions);
                        var pngB64 = await JS.InvokeAsync<string?>("petriEditor.exportDiagramPng", 3072, nodeData);
                        if (!string.IsNullOrEmpty(pngB64))
                            diagramPng = Convert.FromBase64String(pngB64);
                    }

                    // Auto-run analysis if needed
                    if (_expIncludeAnalysis && (_result == null || _analyzedVersion != _netVersion))
                    {
                        _exportStatus = "Running analysis…"; StateHasChanged();
                        _lastDto = dto;
                        try
                        {
                            _result = await ServerAnalysis.RunAnalysisAsync(dto, null, CancellationToken.None);
                            _analyzedVersion = _netVersion;
                        }
                        catch (Exception ex)
                        {
                            throw new Exception($"Analysis failed — the server could not be reached. {ex.Message}", ex);
                        }
                    }

                    // Auto-compute graph if needed
                    if (_expIncludeTree && _refGraphTree != null)
                    {
                        _exportStatus = "Computing reachability graph…"; StateHasChanged();
                        try { await _refGraphTree.EnsureGraphDataAsync(dto); }
                        catch (Exception ex) { throw new Exception($"Graph computation failed: {ex.Message}", ex); }
                    }

                    byte[]? treePng = null;
                    if (_expIncludeTree && _refGraphTree?.GraphData != null)
                    {
                        _exportStatus = "Capturing tree…"; StateHasChanged();
                        await Task.Delay(300);
                        string? pngB64 = await (_refGraphTree?.ExportPngAsync() ?? Task.FromResult<string?>(null));
                        if (!string.IsNullOrEmpty(pngB64))
                            treePng = Convert.FromBase64String(pngB64);
                    }

                    _exportStatus = "Generating PDF…"; StateHasChanged();
                    var options = new ExportOptions(
                        IncludeStructure: _expIncludeStructure,
                        IncludeAnalysis:  _expIncludeAnalysis && _result != null,
                        AnalysisResult:   _expIncludeAnalysis ? _result : null,
                        DiagramPng:       diagramPng,
                        TreePng:          treePng);
                    var bytes = await ExportSvc.ExportAsync(new ExportRequestDto(dto, ExportFormat.Pdf, options));
                    await FileSvc.DownloadAsync("petri.pdf", bytes, "application/pdf");
                    break;
                }
            }

            _exportModalOpen = false;
        }
        catch (Exception ex) { _exportError = ex.Message; }
        finally { _exportRunning = false; _exportStatus = null; StateHasChanged(); }
    }

    private async Task RunAnalysis()
    {
        if (_analysisRunning) return;
        _analysisCts?.Cancel();
        _analysisCts = new CancellationTokenSource();
        _analysisRunning = true;
        _analysisError = null;
        _result = null;
        var versionAtStart = _netVersion;
        _progressMessage = null;
        _refGraphTree?.Reset();
        StateHasChanged();

        try
        {
            var places      = Manager.Diagram.Nodes.OfType<PlaceNode>().ToList();
            var transitions = Manager.Diagram.Nodes.OfType<TransitionNode>().ToList();
            var arcs        = Manager.Diagram.Links.OfType<PetriLinkModel>().ToList();

            var dto = DiagramAnalyzer.BuildDto(places, transitions, arcs);
            _lastDto = dto;

            var ct = _analysisCts.Token;
            var progress = new Progress<AnalysisProgressMessage>(msg =>
            {
                _progressMessage = msg;
                _ = InvokeAsync(StateHasChanged);
            });

            _result = await ServerAnalysis.RunAnalysisAsync(dto, progress, ct);
            if (_activeAnalysisTab == "graph") _refGraphTree?.TryPopulateFromCache();
        }
        catch (OperationCanceledException) { _analysisError = "Analysis cancelled."; }
        catch (Exception ex)
        {
            _analysisError = $"Could not run analysis — the server is unreachable. Please check your connection and try again. ({ex.Message})";
        }
        finally
        {
            // Mark as analyzed at the version captured before analysis started.
            // If the net changed during analysis, _netVersion > versionAtStart and
            // _resultStale will remain true — correct, since result reflects the old net.
            if (_analysisError == null)
                _analyzedVersion = versionAtStart;
            _analysisRunning = false;
            _progressMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        Sim.OnChanged += OnDiagramChanged;
        Manager.Diagram.Nodes.Added   += OnStructuralChange;
        Manager.Diagram.Nodes.Removed += OnStructuralChange;
        Manager.Diagram.Links.Added   += OnStructuralChange;
        Manager.Diagram.Links.Removed += OnStructuralChange;
        Manager.History.HistoryChanged    += OnDiagramChanged;
        Manager.History.StructuralChanged += OnStructuralChange;
    }

    public void Dispose()
    {
        Sim.OnChanged -= OnDiagramChanged;
        Manager.Diagram.Nodes.Added   -= OnStructuralChange;
        Manager.Diagram.Nodes.Removed -= OnStructuralChange;
        Manager.Diagram.Links.Added   -= OnStructuralChange;
        Manager.Diagram.Links.Removed -= OnStructuralChange;
        Manager.History.HistoryChanged    -= OnDiagramChanged;
        Manager.History.StructuralChanged -= OnStructuralChange;
        _analysisCts?.Cancel();
        _analysisCts?.Dispose();
        _dotNetRef?.Dispose();
    }

    private void CancelAnalysis() => _analysisCts?.Cancel();

    private GraphTreePanel? _refGraphTree;


    private void OnDiagramChanged() => InvokeAsync(StateHasChanged);
    // Adapter overloads so event subscriptions with NodeModel / BaseLinkModel args also compile
    private void OnDiagramChanged(NodeModel _) => InvokeAsync(StateHasChanged);
    private void OnDiagramChanged(BaseLinkModel _) => InvokeAsync(StateHasChanged);

    // Fired only for structural (functionally relevant) changes
    private void OnStructuralChange()
    {
        _netVersion++;
        InvokeAsync(StateHasChanged);
    }
    private void OnStructuralChange(NodeModel _) => OnStructuralChange();
    private void OnStructuralChange(BaseLinkModel _) => OnStructuralChange();

    // ── Panel state ───────────────────────────────────────────────────────

    private string PanelStyle => _floating
        ? $"left:{F(_floatX)}px;top:{F(_floatY)}px;width:{F(_floatW)}px;height:{F(_floatH)}px;"
        : $"width:{F(_dockedWidth)}px;";

    private static string F(double v) =>
        v.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    private void ToggleOpen() { _open = !_open; if (_open) _ = SetupJsAsync(); }
    public void Close() { _refGraphTree?.ClearPreview(); _highlightedItemKey = null; _highlightedItemIds = null; _hoverItemKey = null; StateService.ClearHighlight(); _open = false; InvokeAsync(StateHasChanged); }
    private void ToggleFloat() { _floating = !_floating; _ = SetupJsAsync(); }
    private void Maximise()
    {
        _floating = true;
        _ = SetupJsAsync().ContinueWith(_ => JS.InvokeVoidAsync("analysisPanel.maximise").AsTask());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_open) await SetupJsAsync();
    }

    private async Task SetupJsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("analysisPanel.setup",
                _floating, _dockedWidth, DockedMin, DockedMax,
                _floatX, _floatY, _floatW, _floatH, FloatMinW, FloatMinH,
                _dotNetRef);
            await JS.InvokeVoidAsync("analysisPanel.setupTabScroll");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"AnalysisPanel JS setup failed: {ex.Message}");
        }
    }

    [JSInvokable] public void UpdateDockedWidth(double w) { _dockedWidth = Math.Clamp(w, DockedMin, DockedMax); InvokeAsync(StateHasChanged); }
    [JSInvokable] public void UpdateFloating(double x, double y, double w, double h) { _floatX = x; _floatY = y; _floatW = Math.Max(w, FloatMinW); _floatH = Math.Max(h, FloatMinH); InvokeAsync(StateHasChanged); }
}
