@using PetriEditor.Client.Mapping
@using PetriEditor.Client.Services
@using PetriEditor.Shared.Contracts
@inject CytoscapeInterop Cy
@implements IAsyncDisposable

<div id="@_containerId" style="flex:1;min-height:0;background:#fafbfc;"></div>

@code {
    [Parameter] public CoverabilityTreeDto? Tree { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<int?>> OnMarkingHovered { get; set; }
    [Parameter] public EventCallback OnMarkingCleared { get; set; }

    private readonly string _containerId = $"cy-cover-{Guid.NewGuid():N}";
    private CoverabilityTreeDto? _lastRendered;
    private DotNetObjectReference<CytoscapeCallback>? _cbRef;

    public int NodeCount => Tree?.Nodes.Count ?? 0;
    public int EdgeCount => Tree?.Edges.Count ?? 0;
    public bool HasOmega => Tree?.Nodes.Any(n => n.Marking.Any(m => m is null)) == true;
    public bool HasDuplicates => Tree?.Nodes.Any(n => n.IsDuplicate) == true;
    public bool HasDeadlocks => Tree?.Nodes.Any(n => n.IsDeadlock) == true;
    public bool HasTruncated => Tree?.Nodes.Any(n => n.IsTruncated) == true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Tree is null || ReferenceEquals(Tree, _lastRendered)) return;
        _lastRendered = Tree;

        _cbRef?.Dispose();
        _cbRef = DotNetObjectReference.Create(new CytoscapeCallback(OnNodeClicked, OnNodeHovered, OnNodeOut));

        var elements = CytoscapeMapper.FromCoverabilityTree(Tree, Tree.PlaceNames);
        await Cy.InitAsync(_containerId, elements, "breadthfirst", _cbRef);
    }

    private void OnNodeClicked(string _) { }

    private void OnNodeHovered(string nodeId)
    {
        if (Tree == null) return;
        if (!int.TryParse(nodeId, out int id)) return;
        var node = Tree.Nodes.FirstOrDefault(n => n.Id == id);
        if (node == null) return;
        _ = OnMarkingHovered.InvokeAsync(node.Marking);
    }

    private void OnNodeOut() => _ = OnMarkingCleared.InvokeAsync();

    public async Task FitGraph() => await Cy.FitAsync(_containerId);

    public async Task<string?> ExportSvgAsync() => await Cy.ExportSvgAsync(_containerId);

    public async Task<string?> ExportPngAsync(int maxPx = 4096) => await Cy.ExportPngAsync(_containerId, maxPx);

    public async ValueTask DisposeAsync()
    {
        _cbRef?.Dispose();
        await Cy.DestroyAsync(_containerId);
    }
}
