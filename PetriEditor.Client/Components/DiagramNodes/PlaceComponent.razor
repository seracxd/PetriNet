@using Blazor.Diagrams.Components.Renderers
@using PetriNetAnalyzer.DiagramModels
@using PetriNetAnalyzer.Services
@implements IDisposable
@inject DiagramStateService StateService
@inject DiagramSettings Settings
@inject SimulationService Sim

@{
    var _w = Node.Size?.Width  ?? Settings.PlaceSize;
    var _h = Node.Size?.Height ?? Settings.PlaceSize;
}
<div class="petri-node @(Node.Selected && !StateService.IsSimulating ? "selected" : "") @(StateService.IsArcToolActive && !StateService.IsSimulating ? "arc-tool-active" : "")"
     style="width: @(_w)px; height: @(_h)px; position: relative; box-sizing: content-box; @(StateService.IsSimulating ? "cursor:default;" : "")">

    <svg width="@(Node.Size?.Width ?? Settings.PlaceSize)" height="@(Node.Size?.Height ?? Settings.PlaceSize)"
         style="position: absolute; top: 0; left: 0; pointer-events: none; overflow: visible;">

        @if (StateService.IsSimulating && Sim.EnabledTransitions.Count > 0)
        {
            <!-- Subtle pulse ring when simulation running -->
        }

        @{
            var _accentColor = StateService.IsPreviewingMarking && PlaceModel?.Data?.Tokens == int.MaxValue
                ? "#5c6bc0"
                : StateService.IsPreviewingMarking ? "#00a499" : (StateService.IsSimulating ? "#00897b" : null);
        }
        <circle cx="@((Node.Size?.Width ?? Settings.PlaceSize) / 2)"
                cy="@((Node.Size?.Height ?? Settings.PlaceSize) / 2)"
                r="@(((Node.Size?.Width ?? Settings.PlaceSize) / 2) - 2)"
                stroke="@(_accentColor ?? (Node.Selected ? Settings.ArcSelectedColor : Settings.ArcColor))"
                stroke-width="@(Node.Selected && !StateService.IsSimulating && !StateService.IsPreviewingMarking ? 3 : 2)"
                fill="@(StateService.IsPreviewingMarking && PlaceModel?.Data?.Tokens == int.MaxValue ? "#ede7f6" : StateService.IsPreviewingMarking && PlaceModel?.Data?.Tokens > 0 ? "#e8faf8" : (Node.Selected && !StateService.IsSimulating ? "#e3f2fd" : "white"))"
                style="transition: stroke 0.15s, fill 0.15s;" />

        @{
            var _isOmegaPreview = StateService.IsPreviewingMarking && PlaceModel?.Data?.Tokens == int.MaxValue;
        }
        @if (_isOmegaPreview)
        {
            var centerX = (Node.Size?.Width ?? Settings.PlaceSize) / 2;
            var centerY = (Node.Size?.Height ?? Settings.PlaceSize) / 2;
            <g transform="translate(@centerX, @centerY)">
                <text text-anchor="middle" dominant-baseline="central"
                      font-weight="bold" fill="#5c6bc0"
                      style="user-select:none;font-size:20px;transition:all 0.15s;">ω</text>
            </g>
        }
        else if (PlaceModel?.Data?.Tokens > 0)
        {
            var tokens = PlaceModel.Data.Tokens;
            var centerX = (Node.Size?.Width ?? Settings.PlaceSize) / 2;
            var centerY = (Node.Size?.Height ?? Settings.PlaceSize) / 2;
            var tokenColor = _accentColor ?? "black";

            @if (tokens <= 5)
            {
                <g fill="@tokenColor">
                    @foreach (var pos in GetTokenPositions(tokens, centerX, centerY))
                    {
                        <circle cx="@pos.X" cy="@pos.Y" r="6" style="transition: all 0.15s;" />
                    }
                </g>
            }
            else
            {
                <g transform="translate(@centerX, @centerY)">
                    <text text-anchor="middle" dominant-baseline="central"
                          font-weight="bolder" fill="@tokenColor"
                          style="user-select:none;font-size:18px;transition:all 0.15s;">@tokens</text>
                </g>
            }
        }
    </svg>

    @if (!StateService.IsSimulating)
    {
        @foreach (var port in Node.Ports)
        {
            <div style="@GetPortStyle(port)" class="port-anchor">
                <PortRenderer Port="port" />
            </div>
        }
    }

    <div class="node-title">@Node.Title</div>
</div>

@code {
    [Parameter] public NodeModel Node { get; set; } = null!;
    private PlaceNode? PlaceModel => Node as PlaceNode;

    protected override void OnInitialized()
    {
        StateService.OnToolChanged += StateHasChanged;
        StateService.OnSimulationChanged += StateHasChanged;
        Settings.Changed += StateHasChanged;
        Sim.OnChanged += StateHasChanged;
    }

    public void Dispose()
    {
        StateService.OnToolChanged -= StateHasChanged;
        StateService.OnSimulationChanged -= StateHasChanged;
        Settings.Changed -= StateHasChanged;
        Sim.OnChanged -= StateHasChanged;
    }

    private string GetPortStyle(PortModel port)
    {
        var index = Node.Ports.ToList().IndexOf(port);
        string x = "50%", y = "50%";
        switch (index)
        {
            case 0: x = "50%"; y = "3%"; break;
            case 1: x = "82%"; y = "17%"; break;
            case 2: x = "97%"; y = "50%"; break;
            case 3: x = "82%"; y = "82%"; break;
            case 4: x = "50%"; y = "97%"; break;
            case 5: x = "17%"; y = "83%"; break;
            case 6: x = "3%"; y = "50%"; break;
            case 7: x = "17%"; y = "17%"; break;
            default:
                x = port.Alignment switch
                {
                    PortAlignment.Left => "0%",
                    PortAlignment.Right => "100%",
                    _ => "50%"
                };
                y = port.Alignment switch
                {
                    PortAlignment.Top => "0%",
                    PortAlignment.Bottom => "100%",
                    _ => "50%"
                };
                break;
        }
        return $"position: absolute; left: {x}; top: {y}; width: 0; height: 0;";
    }

    private static IEnumerable<(double X, double Y)> GetTokenPositions(int count, double cx, double cy)
    {
        const double s = 9;
        const double l = 13;
        return count switch
        {
            1 => [(cx,     cy)],
            2 => [(cx - s, cy),     (cx + s, cy)],
            3 => [(cx,     cy - s), (cx - s, cy + s),  (cx + s, cy + s)],
            4 => [(cx - s, cy - s), (cx + s, cy - s),  (cx - s, cy + s), (cx + s, cy + s)],
            5 => [(cx - s, cy - s), (cx + s, cy - s), (cx, cy), (cx - s, cy + s), (cx + s, cy + s)],
            _ => Enumerable.Range(0, count).Select(i =>
            {
                double angle = -Math.PI / 2 + i * 2 * Math.PI / count;
                return (cx + 11 * Math.Cos(angle), cy + 11 * Math.Sin(angle));
            })
        };
    }
}
