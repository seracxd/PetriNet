@using Blazor.Diagrams.Components.Renderers
@using Blazor.Diagrams.Core.Models
@using PetriNetAnalyzer.DiagramModels
@using PetriNetAnalyzer.Services
@implements IDisposable
@inject DiagramStateService StateService
@inject DiagramSettings Settings
@inject SimulationService Sim

@{
    var isEnabled = StateService.IsSimulating && Sim.EnabledTransitions.Contains(TransitionModel?.Data?.Id ?? "");
    var isLastFired = Settings.ShowLastFiredHighlight
        && StateService.IsSimulating
        && Sim.LastFiredId == TransitionModel?.Data?.Id;
    var isHighlighted = !StateService.IsSimulating
        && StateService.HighlightedNodeIds.Count > 0
        && TransitionModel?.Data?.Id != null
        && StateService.HighlightedNodeIds.Contains(TransitionModel.Data.Id);
    var _w = Node.Size?.Width  ?? Settings.TransitionWidth;
    var _h = Node.Size?.Height ?? Settings.TransitionHeight;
}

<div class="petri-node @(Node.Selected && !StateService.IsSimulating ? "selected" : "") @(StateService.ShouldShowPorts && !StateService.IsSimulating ? "arc-tool-active" : "")"
     style="width: @(_w)px; height: @(_h)px; position: relative; @(StateService.IsSimulating ? "cursor:default;" : "")"
     @onclick="@OnClick">

    <svg width="@_w" height="@_h"
         style="position: absolute; top: 0; left: 0; pointer-events: none; overflow: visible;
                @(isHighlighted ? "filter: drop-shadow(0 0 4px rgba(124,58,237,0.5)) drop-shadow(0 0 10px rgba(124,58,237,0.25));" :
                  Node.Selected && !StateService.IsSimulating ? "filter: drop-shadow(0 0 5px rgba(0, 123, 255, 0.8));" :
                  isLastFired ? "filter: drop-shadow(0 0 6px rgba(0,230,180,1)) drop-shadow(0 0 14px rgba(0,230,180,1)) drop-shadow(0 0 28px rgba(0,230,180,0.9));" : "")">

        <rect x="0" y="0"
              width="@_w"
              height="@_h"
              fill="@(isHighlighted ? "#ede9fe" : isEnabled ? "#4db6ac" : Settings.ArcColor)"
              stroke="@(isHighlighted ? "#7c3aed" : Node.Selected && !StateService.IsSimulating ? Settings.ArcSelectedColor : Settings.ArcColor)"
              stroke-width="@(isHighlighted || (Node.Selected && !StateService.IsSimulating) ? 3 : 2)"
              stroke-dasharray="@(isHighlighted ? "6 3" : "none")"
              style="transition: fill 0.2s;" />

        @if (TransitionModel?.Data?.Priority > 0)
        {
            var badgeX = _w / 2.0;
            var badgeY = -14.0;
            <g>
                <circle cx="@badgeX" cy="@badgeY" r="11"
                        fill="#ff4081" stroke="white" stroke-width="1.5" />
                <text x="@badgeX" y="@badgeY"
                      text-anchor="middle" dominant-baseline="central"
                      fill="white" font-size="11" font-weight="bold"
                      style="user-select:none;">
                    @TransitionModel!.Data.Priority
                </text>
            </g>
        }
    </svg>

    @if (!StateService.IsSimulating)
    {
        @foreach (var port in Node.Ports)
        {
            <div style="@GetPortStyle(port)" class="port-anchor">
                <PortRenderer Port="port" />
            </div>
        }
    }

    <div class="node-title">@Node.Title</div>
</div>

@code {
    [Parameter] public NodeModel Node { get; set; } = null!;
    private TransitionNode? TransitionModel => Node as TransitionNode;

    private void OnClick()
    {
        if (!StateService.IsSimulating) return;
        if (TransitionModel?.Data == null) return;
        if (!Sim.EnabledTransitions.Contains(TransitionModel.Data.Id)) return;
        Sim.StepManual(TransitionModel.Data.Id);
    }

    protected override void OnInitialized()
    {
        StateService.OnToolChanged += StateHasChanged;
        StateService.OnSimulationChanged += StateHasChanged;
        StateService.OnHighlightChanged += StateHasChanged;
        Settings.Changed += StateHasChanged;
        Sim.OnChanged += StateHasChanged;
    }

    public void Dispose()
    {
        StateService.OnToolChanged -= StateHasChanged;
        StateService.OnSimulationChanged -= StateHasChanged;
        StateService.OnHighlightChanged -= StateHasChanged;
        Settings.Changed -= StateHasChanged;
        Sim.OnChanged -= StateHasChanged;
    }

    private string GetPortStyle(PortModel port)
    {
        var allPorts = Node.Ports.ToList();
        var indexInAlignment = allPorts.Where(p => p.Alignment == port.Alignment).ToList().IndexOf(port);
        string x = "50%", y = "50%";

        switch (port.Alignment)
        {
            case PortAlignment.Left:
                x = "0%";
                y = indexInAlignment == 0 ? "25%" : indexInAlignment == 1 ? "50%" : "75%";
                break;
            case PortAlignment.Right:
                x = "100%";
                y = indexInAlignment == 0 ? "25%" : indexInAlignment == 1 ? "50%" : "75%";
                break;
            case PortAlignment.Top: x = "50%"; y = "0%"; break;
            case PortAlignment.Bottom: x = "50%"; y = "100%"; break;
        }
        return $"position: absolute; left: {x}; top: {y}; width: 0; height: 0;";
    }
}
