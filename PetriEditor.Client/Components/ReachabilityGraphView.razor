@using PetriEditor.Client.Mapping
@using PetriEditor.Client.Services
@using PetriEditor.Shared.Contracts
@inject CytoscapeInterop Cy
@implements IAsyncDisposable

<div style="display:flex;flex-direction:column;gap:6px;">

    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
        <button @onclick="FitGraph"
                style="padding:4px 10px;background:#f0faf8;border:1px solid #00897b;border-radius:6px;font-size:11px;color:#00897b;cursor:pointer;font-weight:600;">
            Fit to screen
        </button>
        <span style="font-size:10px;color:#aaa;">
            @(Graph?.Nodes.Count ?? 0) nodes · @(Graph?.Edges.Count ?? 0) edges
        </span>
        @if (Graph?.Nodes.Any(n => n.IsDuplicate) == true)
        {
            <span style="font-size:10px;padding:2px 6px;background:#f3e5f5;border-radius:8px;color:#7b1fa2;">
                dashed = duplicate marking
            </span>
        }
        @if (Graph?.Nodes.Any(n => n.IsDeadlock) == true)
        {
            <span style="font-size:10px;padding:2px 6px;background:#ffebee;border-radius:8px;color:#c62828;">
                red = deadlock
            </span>
        }
    </div>

    <div id="@_containerId"
         style="width:100%;height:460px;border:1px solid #e0e0e0;border-radius:8px;background:#fafafa;">
    </div>

</div>

@code {
    [Parameter] public ReachabilityGraphDto? Graph { get; set; }

    // Unique container id so multiple instances on the same page don't clash
    private readonly string _containerId = $"cy-reach-{Guid.NewGuid():N}";
    private ReachabilityGraphDto? _lastRendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Graph is null || ReferenceEquals(Graph, _lastRendered))
            return;

        _lastRendered = Graph;

        var elements = CytoscapeMapper.FromReachabilityGraph(Graph, Graph.PlaceNames);
        await Cy.InitAsync(_containerId, elements, "breadthfirst");
    }

    private async Task FitGraph() => await Cy.FitAsync(_containerId);

    public async ValueTask DisposeAsync() => await Cy.DestroyAsync(_containerId);
}
