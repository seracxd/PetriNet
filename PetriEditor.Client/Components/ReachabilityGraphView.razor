@using PetriEditor.Client.Mapping
@using PetriEditor.Client.Services
@using PetriEditor.Shared.Contracts
@inject CytoscapeInterop Cy
@implements IAsyncDisposable

<div id="@_containerId" style="flex:1;min-height:0;background:#fafbfc;"></div>

@code {
    [Parameter] public ReachabilityGraphDto? Graph { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<int?>> OnMarkingHovered { get; set; }
    [Parameter] public EventCallback OnMarkingCleared { get; set; }

    private readonly string _containerId = $"cy-reach-{Guid.NewGuid():N}";
    private ReachabilityGraphDto? _lastRendered;
    private DotNetObjectReference<CytoscapeCallback>? _cbRef;

    public int NodeCount => Graph?.Nodes.Count ?? 0;
    public int EdgeCount => Graph?.Edges.Count ?? 0;
    public bool HasDuplicates => Graph?.Nodes.Any(n => n.IsDuplicate) == true;
    public bool HasDeadlocks => Graph?.Nodes.Any(n => n.IsDeadlock) == true;
    public bool HasTruncated => Graph?.Nodes.Any(n => n.IsTruncated) == true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Graph is null || ReferenceEquals(Graph, _lastRendered)) return;
        _lastRendered = Graph;

        _cbRef?.Dispose();
        _cbRef = DotNetObjectReference.Create(new CytoscapeCallback(OnNodeClicked, OnNodeHovered, OnNodeOut));

        var elements = CytoscapeMapper.FromReachabilityGraph(Graph, Graph.PlaceNames);
        await Cy.InitAsync(_containerId, elements, "breadthfirst", _cbRef);
    }

    private void OnNodeClicked(string _) { }

    private void OnNodeHovered(string nodeId)
    {
        if (Graph == null) return;
        if (!int.TryParse(nodeId, out int id)) return;
        var node = Graph.Nodes.FirstOrDefault(n => n.Id == id);
        if (node == null) return;
        _ = OnMarkingHovered.InvokeAsync(node.Marking.Select(t => (int?)t).ToList());
    }

    private void OnNodeOut() => _ = OnMarkingCleared.InvokeAsync();


    public async Task FitGraph() => await Cy.FitAsync(_containerId);

    public async ValueTask DisposeAsync()
    {
        _cbRef?.Dispose();
        await Cy.DestroyAsync(_containerId);
    }
}
