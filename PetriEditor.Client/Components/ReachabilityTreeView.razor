@using PetriEditor.Shared.Contracts
@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_containerId" style="flex:1;min-height:0;overflow:hidden;background:#fafbfc;cursor:grab;user-select:none;touch-action:none;position:relative;">
    <svg width="100%" height="100%" preserveAspectRatio="none" style="display:block;position:absolute;top:0;left:0;"></svg>
</div>

@code {
    [Parameter] public ReachabilityGraphDto? Graph { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<int?>> OnMarkingHovered { get; set; }
    [Parameter] public EventCallback OnMarkingCleared { get; set; }
    [Parameter] public int MaxDisplayNodes { get; set; } = 500;

    // Layout constants — used during AssignX; may be scaled down before passing to JS
    const double NodeW   = 60;
    const double NodeH   = 30;
    const double LevelH  = 60;
    const double MinGapX = 12;
    const double MaxSvgW = 8000;  // cap; everything scales together so no overlaps

    private double _nodeW = NodeW;   // actual rendered size after scaling
    private double _nodeH = NodeH;

    private readonly string _containerId = $"tree-{Guid.NewGuid():N}";
    private ReachabilityGraphDto? _lastGraph;
    private Dictionary<int, LayoutNode>? _layout;
    private List<(LayoutNode From, LayoutNode To, string Label, bool Dashed)> _edges = new();
    private double _svgW, _svgH;
    private bool _hasDuplicates, _hasDeadlocks, _truncated;
    private string? _hoveredMarkingKey;

    private Dictionary<int, string> _nodeLabels = new();

    private sealed class LayoutNode
    {
        public ReachNodeDto Node;
        public string Label       = "";
        public string RefLabel    = "";
        public string MarkingKey  = "";
        public bool   IsReference;
        public bool   IsCutOff;   // true = server truncated OR client display limit cut children
        public int    CanonicalId = -1;
        public int    Col;        // grid column (integer slot)
        public double X, Y;
        public LayoutNode(ReachNodeDto node) { Node = node; }
    }

    private DotNetObjectReference<ReachabilityTreeView>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Graph is null || ReferenceEquals(Graph, _lastGraph)) return;
        _lastGraph = Graph;
        BuildLayout();

        if (_layout == null || _layout.Count == 0) return;

        _dotNetRef ??= DotNetObjectReference.Create(this);

        var nodes = _layout.Values.Select(n => new
        {
            x           = n.X,
            y           = n.Y,
            label       = n.Label,
            isRef       = n.IsReference,
            isCutOff    = n.IsCutOff,
            refLabel    = n.RefLabel,
            canonicalId = n.CanonicalId,
            isInit      = n.Node.IsInitial,
            isDead      = n.Node.IsDeadlock,
            markingKey  = n.MarkingKey,
            markingTip  = string.Join(", ", n.Node.Marking),
        }).ToArray();

        var edges = _edges.Select(e => new
        {
            x1    = e.From.X + _nodeW / 2.0,
            y1    = e.From.Y + _nodeH,
            x2    = e.To.X + _nodeW / 2.0,
            y2    = e.To.Y,
            label = e.Label,
        }).ToArray();

        var placeNames = Graph!.PlaceNames;
        await JS.InvokeVoidAsync("treeView.init", _containerId, nodes, edges, _svgW, _svgH, _nodeW, _nodeH, placeNames, _dotNetRef);
    }

    [JSInvokable]
    public async Task OnNodeHovered(string markingKey, string markingCsv)
    {
        _hoveredMarkingKey = markingKey;
        if (!string.IsNullOrEmpty(markingCsv))
        {
            var tokens = markingCsv.Split(',')
                .Select(s => int.TryParse(s, out int v) ? (int?)v : null)
                .ToList();
            await OnMarkingHovered.InvokeAsync(tokens);
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnNodeLeft()
    {
        _hoveredMarkingKey = null;
        await OnMarkingCleared.InvokeAsync();
        StateHasChanged();
    }

    private void BuildLayout()
    {
        _layout    = new();
        _edges     = new();
        _truncated = false;

        if (Graph!.Nodes.Count == 0) { _svgW = 400; _svgH = 200; return; }

        var allNodes = Graph.Nodes;
        var allEdges = Graph.Edges;
        var cutOffIds = new HashSet<int>(allNodes.Where(n => n.IsTruncated).Select(n => n.Id));

        if (allNodes.Count > MaxDisplayNodes)
        {
            _truncated = true;
            var rootNode = allNodes.FirstOrDefault(n => n.IsInitial) ?? allNodes[0];
            var keep = new HashSet<int>();
            var q = new Queue<int>();
            q.Enqueue(rootNode.Id);
            keep.Add(rootNode.Id);
            var childMap = allNodes.ToDictionary(n => n.Id, _ => new List<int>());
            foreach (var n in allNodes)
                if (n.ParentId >= 0 && childMap.ContainsKey(n.ParentId))
                    childMap[n.ParentId].Add(n.Id);
            while (q.Count > 0 && keep.Count < MaxDisplayNodes)
            {
                int cur = q.Dequeue();
                foreach (int ch in childMap[cur])
                    if (keep.Count < MaxDisplayNodes && keep.Add(ch))
                        q.Enqueue(ch);
                    else if (!keep.Contains(ch))
                        cutOffIds.Add(cur); // this node had children that didn't make the cut
            }
            allNodes = allNodes.Where(n => keep.Contains(n.Id)).ToList();
            allEdges = allEdges.Where(e => keep.Contains(e.From) && keep.Contains(e.To)).ToList();
        }

        _hasDuplicates = allNodes.Any(n => n.IsDuplicate);
        _hasDeadlocks  = allNodes.Any(n => n.IsDeadlock);

        var children = allNodes.ToDictionary(n => n.Id, _ => new List<int>());
        foreach (var n in allNodes)
            if (n.ParentId >= 0 && children.ContainsKey(n.ParentId))
                children[n.ParentId].Add(n.Id);

        var markingKey  = new Dictionary<string, int>();
        var canonical   = new Dictionary<int, int>();
        foreach (var n in allNodes)
        {
            var key = string.Join(",", n.Marking);
            if (markingKey.TryGetValue(key, out int cId))
                canonical[n.Id] = cId;
            else
            {
                markingKey[key] = n.Id;
                canonical[n.Id] = n.Id;
            }
        }

        int labelIdx = 0;
        _nodeLabels.Clear();
        var root = allNodes.FirstOrDefault(n => n.IsInitial) ?? allNodes[0];
        var bfsQ = new Queue<int>();
        var bfsVisited = new HashSet<int>();
        bfsQ.Enqueue(root.Id);
        bfsVisited.Add(root.Id);
        while (bfsQ.Count > 0)
        {
            int cur = bfsQ.Dequeue();
            _nodeLabels[cur] = labelIdx == 0 ? "M₀" : $"M{labelIdx}";
            labelIdx++;
            foreach (int ch in children[cur])
                if (canonical[ch] == ch && bfsVisited.Add(ch))
                    bfsQ.Enqueue(ch);
        }

        var nodeById = allNodes.ToDictionary(n => n.Id);

        foreach (var n in allNodes)
        {
            var ln = new LayoutNode(n);
            bool isRef = canonical[n.Id] != n.Id;
            ln.IsReference = isRef;
            ln.IsCutOff    = cutOffIds.Contains(n.Id);
            ln.Label = _nodeLabels.GetValueOrDefault(canonical[n.Id], "M?");
            ln.MarkingKey = string.Join(",", n.Marking);
            if (isRef)
            {
                ln.CanonicalId = canonical[n.Id];
                ln.RefLabel = _nodeLabels.GetValueOrDefault(canonical[n.Id], "");
                if (nodeById.TryGetValue(canonical[n.Id], out var canonNode))
                    ln.Node = canonNode;
            }
            _layout[n.Id] = ln;
        }

        var depth = new Dictionary<int, int> { [root.Id] = 0 };
        var q2 = new Queue<int>();
        q2.Enqueue(root.Id);
        while (q2.Count > 0)
        {
            int cur = q2.Dequeue();
            foreach (int ch in children[cur])
            {
                if (!depth.ContainsKey(ch))
                {
                    depth[ch] = depth[cur] + 1;
                    q2.Enqueue(ch);
                }
            }
        }
        foreach (var (id, ln) in _layout)
            ln.Y = depth.GetValueOrDefault(id, 0) * LevelH;

        // Grid-based layout: every node gets an integer (col, row).
        // We walk post-order DFS, placing children then centering the parent.
        // A row-occupancy set prevents collisions; if a desired column is taken
        // we shift right, pulling the entire subtree along.
        var rowOccupied = new Dictionary<int, HashSet<int>>(); // row → set of occupied cols
        AssignGrid(root.Id, children, depth, rowOccupied);

        double pad  = 24;
        double slot = NodeW + MinGapX;

        int maxCol = _layout.Values.Max(n => n.Col);
        double rawW = (maxCol + 1) * slot + pad * 2;
        double scale = rawW > MaxSvgW ? (MaxSvgW - pad * 2) / ((maxCol + 1) * slot) : 1.0;
        double scaledSlot = slot * scale;

        foreach (var ln in _layout.Values)
            ln.X = pad + ln.Col * scaledSlot;

        _nodeW = NodeW * scale;
        _nodeH = NodeH;   // Y is never scaled

        double maxX = _layout.Values.Max(n => n.X) + _nodeW + pad;
        double maxY = _layout.Values.Max(n => n.Y) + NodeH + pad + 16;
        _svgW = Math.Max(maxX, 300);
        _svgH = Math.Max(maxY, 200);

        var edgeLabel = new Dictionary<(int, int), string>();
        foreach (var e in allEdges)
            edgeLabel.TryAdd((e.From, e.To), e.TransitionName);

        foreach (var n in allNodes)
        {
            if (n.ParentId < 0) continue;
            if (!_layout.TryGetValue(n.ParentId, out var fromLn)) continue;
            if (!_layout.TryGetValue(n.Id,       out var toLn))   continue;
            string lbl = edgeLabel.GetValueOrDefault((n.ParentId, n.Id), "");
            _edges.Add((fromLn, toLn, lbl, toLn.IsReference));
        }
    }

    /// <summary>
    /// Compact grid layout.  Every node gets an integer column.
    ///
    /// Algorithm — DFS post-order, two passes:
    ///   Pass 1: compute relative column offsets within each subtree.
    ///           Leaves are at offset 0.  An internal node's children are laid
    ///           out left-to-right with the minimum gap that avoids collision
    ///           at every row.  The parent is centered over its children.
    ///   Pass 2: convert relative offsets to absolute columns by adding parent's
    ///           absolute column.
    ///
    /// The "contour" merging (Reingold-Tilford style) ensures subtrees pack
    /// tightly.  Integer rounding keeps everything on a strict grid.
    /// </summary>
    private void AssignGrid(int id, Dictionary<int, List<int>> children,
                            Dictionary<int, int> depth,
                            Dictionary<int, HashSet<int>> rowOccupied)
    {
        // Pass 1: compute relative positions within each subtree
        var relCol = new Dictionary<int, int>(); // node → col relative to subtree root
        ComputeRelative(id, children, depth, relCol);

        // Pass 2: find leftmost absolute start so nothing goes negative,
        // then shift the whole tree right if needed to avoid existing placements
        int minRel = relCol.Values.Min();
        int shift  = -minRel; // make minimum relative col = 0

        // Check against already-occupied columns (for multi-root scenarios, though
        // we usually have one root)
        foreach (var (nid, rc) in relCol)
        {
            int row = depth[nid];
            int absCol = rc + shift;
            if (rowOccupied.TryGetValue(row, out var occ) && occ.Contains(absCol))
            {
                // Shouldn't happen for a single-root tree but guard anyway
                shift = occ.Max() + 1 - rc;
            }
        }

        foreach (var (nid, rc) in relCol)
        {
            int row = depth[nid];
            int absCol = rc + shift;
            _layout![nid].Col = absCol;
            if (!rowOccupied.ContainsKey(row)) rowOccupied[row] = new();
            rowOccupied[row].Add(absCol);
        }
    }

    /// <summary>
    /// Compute relative column for every node in the subtree rooted at <paramref name="id"/>.
    /// The root of the subtree gets column 0 (which may shift later).
    /// Returns (leftContour, rightContour) — per-depth min/max relative columns.
    /// </summary>
    private (Dictionary<int, int> Left, Dictionary<int, int> Right) ComputeRelative(
        int id, Dictionary<int, List<int>> children,
        Dictionary<int, int> depth, Dictionary<int, int> relCol)
    {
        int myDepth = depth[id];
        var ch = children[id];

        if (ch.Count == 0)
        {
            relCol[id] = 0;
            var l = new Dictionary<int, int> { [myDepth] = 0 };
            var r = new Dictionary<int, int> { [myDepth] = 0 };
            return (l, r);
        }

        // Lay out children left to right, merging contours
        var childRoots = new List<(int childId, int offset)>();
        Dictionary<int, int>? mergedLeft = null, mergedRight = null;
        int nextOffset = 0;

        for (int i = 0; i < ch.Count; i++)
        {
            var (cl, cr) = ComputeRelative(ch[i], children, depth, relCol);

            if (i == 0)
            {
                // First child goes at offset 0
                childRoots.Add((ch[i], 0));
                mergedLeft  = new(cl);
                mergedRight = new(cr);
            }
            else
            {
                // Find minimum gap: for each overlapping depth, compute how far
                // right the new subtree must shift so its left contour clears
                // the merged right contour by at least 1 column.
                int minShift = nextOffset; // at least after previous child
                foreach (var (d, leftVal) in cl)
                {
                    if (mergedRight!.TryGetValue(d, out int rightVal))
                    {
                        int needed = rightVal - leftVal + 2; // +2 = 1 column gap
                        if (needed > minShift) minShift = needed;
                    }
                }

                childRoots.Add((ch[i], minShift));

                // Merge contours
                foreach (var (d, v) in cl)
                {
                    int shifted = v + minShift;
                    if (!mergedLeft!.ContainsKey(d) || shifted < mergedLeft[d])
                        mergedLeft[d] = shifted;
                }
                foreach (var (d, v) in cr)
                {
                    int shifted = v + minShift;
                    if (!mergedRight!.ContainsKey(d) || shifted > mergedRight[d])
                        mergedRight[d] = shifted;
                }
            }

            nextOffset = childRoots[^1].offset + 1; // minimum for next sibling
        }

        // Center parent over its children
        int leftChild  = childRoots[0].offset + relCol[ch[0]];
        int rightChild = childRoots[^1].offset + relCol[ch[^1]];
        int parentCol  = (leftChild + rightChild) / 2;

        // Shift everything so parent is at 0
        relCol[id] = 0;
        foreach (var (childId, offset) in childRoots)
            ShiftSubtree(childId, children, relCol, offset - parentCol);

        // Rebuild contours relative to parent=0
        int parentShift = -parentCol;
        var finalLeft  = new Dictionary<int, int> { [myDepth] = 0 };
        var finalRight = new Dictionary<int, int> { [myDepth] = 0 };
        foreach (var (d, v) in mergedLeft!)
        {
            int sv = v + parentShift;
            if (!finalLeft.ContainsKey(d) || sv < finalLeft[d])
                finalLeft[d] = sv;
        }
        foreach (var (d, v) in mergedRight!)
        {
            int sv = v + parentShift;
            if (!finalRight.ContainsKey(d) || sv > finalRight[d])
                finalRight[d] = sv;
        }

        return (finalLeft, finalRight);
    }

    private void ShiftSubtree(int id, Dictionary<int, List<int>> children,
                              Dictionary<int, int> relCol, int delta)
    {
        relCol[id] += delta;
        foreach (int ch in children[id])
            ShiftSubtree(ch, children, relCol, delta);
    }

    public int NodeCount => _layout?.Count ?? 0;
    public bool HasDuplicates => _hasDuplicates;
    public bool HasDeadlocks => _hasDeadlocks;
    public bool IsTruncated => _truncated;

    public async Task ResetView() =>
        await JS.InvokeVoidAsync("treeView.resetView", _containerId);

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("treeView.destroy", _containerId); } catch { }
        _dotNetRef?.Dispose();
    }

    private static string F(double v) =>
        v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
}
