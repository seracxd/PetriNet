@using Blazor.Diagrams.Core.Models.Base
@using PetriNetAnalyzer.DiagramModels

@if (Model is PetriLinkModel link && link.Selected && !link.IsDraggingEndpoint)
{
    <rect x="-6" y="-6" width="12" height="12"
          fill="#ff8c00"
          stroke="white"
          stroke-width="1.5"
          transform="rotate(45)"
          style="cursor:crosshair;"
          @onpointerdown="OnPointerDown"
          @onpointerdown:stopPropagation="true" />
}
else
{
    @* Invisible hit area even when not selected so the control position is still computed *@
    <rect x="-15" y="-15" width="30" height="30"
          fill="transparent"
          stroke="transparent"
          @onpointerdown="OnPointerDown"
          @onpointerdown:stopPropagation="true" />
}

@code {
    [CascadingParameter] public Blazor.Diagrams.BlazorDiagram Diagram { get; set; } = null!;
    [Parameter] public PetriEndpointControl Control { get; set; } = null!;
    [Parameter] public Model Model { get; set; } = null!;

    private void OnPointerDown(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        Control.StartDrag(Diagram, Model, e.ClientX, e.ClientY);
    }
}
