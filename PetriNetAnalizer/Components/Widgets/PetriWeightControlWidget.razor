@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models.Base
@using PetriNetAnalyzer.DiagramModels
@using PetriNetAnalyzer.Components.Widgets
@implements IDisposable

@* Visible whenever weight > 1, regardless of selection *@
@if (Model is PetriLinkModel link && link.Weight > 1)
{
    <foreignObject x="-20" y="-12" width="40" height="24" style="overflow:visible;">
        <div class="petri-weight"
             style="cursor:@(_dragging ? "grabbing" : "grab");"
             @onpointerdown="(e) => OnPointerDown(link, e)"
             @onpointerdown:stopPropagation="true">
            @link.Weight
        </div>
    </foreignObject>
}

@code {
    [CascadingParameter] public Blazor.Diagrams.BlazorDiagram Diagram { get; set; } = null!;
    [Parameter] public PetriWeightControl Control { get; set; } = null!;
    [Parameter] public Model Model { get; set; } = null!;

    private bool _dragging;
    private Point _dragStartMouse;
    private Point _dragStartOffset;

    protected override void OnInitialized()
    {
        Diagram.PointerMove += OnDiagramPointerMove;
        Diagram.PointerUp += OnDiagramPointerUp;
    }

    public void Dispose()
    {
        Diagram.PointerMove -= OnDiagramPointerMove;
        Diagram.PointerUp -= OnDiagramPointerUp;
    }

    private void OnPointerDown(PetriLinkModel link, PointerEventArgs e)
    {
        _dragging = true;
        _dragStartMouse = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        _dragStartOffset = link.WeightLabelOffset;
    }

    private void OnDiagramPointerMove(Model? _, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (!_dragging || Model is not PetriLinkModel link) return;

        var mouse = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        link.WeightLabelOffset = new Point(
            _dragStartOffset.X + mouse.X - _dragStartMouse.X,
            _dragStartOffset.Y + mouse.Y - _dragStartMouse.Y);

        link.Refresh();
        InvokeAsync(StateHasChanged);
    }

    private void OnDiagramPointerUp(Model? _, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (!_dragging) return;
        _dragging = false;
        InvokeAsync(StateHasChanged);
    }
}
