@page "/"
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models.Base
@using PetriNetAnalyzer.DiagramModels
@using PetriNetAnalyzer.Services
@implements IDisposable
@inject DiagramStateService StateService
@inject PetriNetManager Manager

<div class="app-frame">
	<div class="app-container">

		<div class="topbar">
			<div class="topbar-title">Net Model</div>
		</div>

		<div class="content-wrapper">

			<div class="sidebar">
				<div class="sidebar-title">Tools</div>
				<div class="sidebar-divider"></div>

				<button class="tool-btn @(ActiveTool == "select" ? "active" : "")"
						@onclick='() => SetTool("select")'>
					🖱
				</button>
				<button class="tool-btn @(ActiveTool == "place" ? "active" : "")"
						@onclick='() => SetTool("place")'>
					⚪
				</button>
				<button class="tool-btn @(ActiveTool == "transition" ? "active" : "")"
						@onclick='() => SetTool("transition")'>
					▮
				</button>
				<button class="tool-btn @(ActiveTool == "arc" ? "active" : "") @(Manager.HasPendingLink ? "pending" : "")"
						@onclick='() => SetTool("arc")'>
					↗
				</button>

				<div class="sidebar-section-title">Properties</div>
				<div class="sidebar-divider"></div>

				<div class="properties-panel">
					@if (SelectedModel is PlaceNode p)
					{
						<div class="prop-field">
							<div class="prop-label">Name</div>
							<input class="prop-input" @bind-value="p.Data.Name" @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(p)" />
						</div>
						<div class="prop-field">
							<div class="prop-label">Tokens</div>
							<input class="prop-input" type="number" @bind-value="p.Data.Tokens" @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(p)" />
						</div>
					}
					else if (SelectedModel is TransitionNode t)
					{
						<div class="prop-field">
							<div class="prop-label">Name</div>
							<input class="prop-input" @bind-value="t.Data.Name" @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(t)" />
						</div>
					}
					else if (SelectedModel is PetriLinkModel a)
					{
						<div class="prop-field">
							<div class="prop-label">Weight</div>
							<input class="prop-input" type="number" @bind-value="a.Weight" @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(a)" />
						</div>
					}
					else
					{
						<div class="prop-empty">No element selected.</div>
					}
				</div>
			</div>

			<div id="diagram-container" tabindex="0">
				<CascadingValue Value="Manager.Diagram" IsFixed="true">
					<DiagramCanvas />
				</CascadingValue>
			</div>

		</div>
	</div>
</div>

@code {
	private string ActiveTool = "";
	private Model? SelectedModel { get; set; }

	protected override void OnInitialized()
	{
		Manager.Diagram.PointerDown += OnPointerDown;
		Manager.Diagram.PointerDoubleClick += OnDoubleClick;
		Manager.Diagram.KeyDown += OnKeyDown;
		Manager.Diagram.SelectionChanged += OnSelectionChanged;
		Manager.PendingLinkChanged += OnPendingLinkChanged;
	}

	private void OnPendingLinkChanged() => InvokeAsync(StateHasChanged);

	private void OnSelectionChanged(SelectableModel _)
	{
		SelectedModel = Manager.Diagram.GetSelectedModels().FirstOrDefault();
		InvokeAsync(StateHasChanged);
	}

	private void SetTool(string tool)
	{
		ActiveTool = ActiveTool == tool ? "" : tool;

		var serviceToolType = ActiveTool == "arc"
			? DiagramStateService.ToolType.Arc
			: DiagramStateService.ToolType.Select;
		StateService.SelectTool(serviceToolType);

		if (ActiveTool == "arc")
			Manager.EnableLinkDrawing();
		else
			Manager.DisableLinkDrawing();
	}

	private void UpdateDiagram(Model? model = null)
	{
		SyncRenderedText(model);
		if (model is NodeModel node) node.Refresh();
		else if (model is PetriLinkModel link) link.Refresh();
		Manager.Diagram.Refresh();
		InvokeAsync(StateHasChanged);
	}

	private void SyncRenderedText(Model? model)
	{
		if (model is PlaceNode p) p.Title = p.Data.Name;
		else if (model is TransitionNode t) t.Title = t.Data.Name;
	}

	private void OnPointerDown(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
	{
		if (ActiveTool == "arc")
		{
			Manager.HandleArcToolClick(model, new Point(e.ClientX, e.ClientY));
			StateHasChanged();
			return;
		}

		// place / transition tool — add node on blank canvas click
		if (model == null && ActiveTool is "place" or "transition")
		{
			Manager.AddNodeAt(ActiveTool, new Point(e.ClientX, e.ClientY));
			StateHasChanged();
		}
	}

	private void OnDoubleClick(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
	{
		Manager.HandleDoubleClick(model, new Point(e.ClientX, e.ClientY));
		StateHasChanged();
	}

	private void OnKeyDown(Blazor.Diagrams.Core.Events.KeyboardEventArgs e)
	{
		if (e.Key == "Escape")
		{
			Manager.CancelPendingLink();
			InvokeAsync(StateHasChanged);
			return;
		}
		if (e.Key == "Delete" || e.Key == "Backspace")
		{
			Manager.DeleteSelected();
			InvokeAsync(StateHasChanged);
		}
	}

	public void Dispose()
	{
		Manager.Diagram.PointerDown -= OnPointerDown;
		Manager.Diagram.PointerDoubleClick -= OnDoubleClick;
		Manager.Diagram.KeyDown -= OnKeyDown;
		Manager.Diagram.SelectionChanged -= OnSelectionChanged;
		Manager.PendingLinkChanged -= OnPendingLinkChanged;
	}
}
