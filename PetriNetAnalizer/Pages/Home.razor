@page "/"
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models.Base
@using Core.Models
@using PetriNetAnalyzer.DiagramModels
@using PetriNetAnalyzer.Services
@using Microsoft.JSInterop
@implements IDisposable
@inject DiagramStateService StateService
@inject PetriNetManager Manager
@inject IJSRuntime JS
@inject DiagramSettings Settings
@inject SimulationService Sim

<div class="app-root">

    <header class="topbar">
        <span class="topbar-title">Net Model</span>
    </header>

    <div class="body-row">

        @* ── Sidebar ── *@
        <aside class="sidebar">

            @if (StateService.IsSimulating)
            {
                @* ── Simulation controls ── *@
                <section class="sidebar-section">
                    <div class="section-label" style="color:#00897b;">Simulation</div>

                    @* Step counter *@
                    <div style="font-size:11px;color:#aaa;margin-bottom:8px;">Step @Sim.StepCount</div>

                    @* Control buttons row *@
                    <div style="display:flex;gap:6px;margin-bottom:10px;">
                        @* Stop *@
                        <button class="tool-btn" title="Stop simulation" @onclick="StopSimulation"
                                style="flex:1;background:#ffebee;border-color:#ffcdd2;color:#e53935;">
                            <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px;">
                                <rect x="4" y="4" width="16" height="16" rx="2" />
                            </svg>
                        </button>
                        @* Reset *@
                        <button class="tool-btn" title="Reset to initial marking" @onclick="ResetSimulation"
                                style="flex:1;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                                <polyline points="1 4 1 10 7 10" />
                                <path d="M3.51 15a9 9 0 1 0 .49-4.95" />
                            </svg>
                        </button>
                        @* Step once (manual/highest priority) *@
                        <button class="tool-btn @(Sim.IsDeadlock ? "disabled" : "")" title="Step once" @onclick="StepOnce"
                                disabled="@Sim.IsDeadlock" style="flex:1;">
                            <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px;">
                                <polygon points="5 4 15 12 5 20 5 4" />
                                <line x1="19" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            </svg>
                        </button>
                    </div>

                    @* Auto fire toggle *@
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button @onclick="() => Sim.ToggleAuto()"
                                style="flex:1;padding:6px 0;border-radius:7px;border:1.5px solid @(Sim.IsAutoFiring ? "#00897b" : "#e0e0e0");background:@(Sim.IsAutoFiring ? "#e0f5f3" : "#fff");color:@(Sim.IsAutoFiring ? "#00897b" : "#888");font-size:11px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;">
                                <polygon points="5 3 19 12 5 21 5 3" />
                            </svg>
                            @(Sim.IsAutoFiring ? "Auto: ON" : "Auto: OFF")
                        </button>
                    </div>

                    @* Delay slider *@
                    <div style="margin-bottom:10px;">
                        <div style="display:flex;justify-content:space-between;font-size:10px;color:#aaa;margin-bottom:4px;">
                            <span>Firing delay</span><span>@Sim.FiringDelay ms</span>
                        </div>
                        <input type="range" min="100" max="3000" step="100"
                               value="@Sim.FiringDelay"
                               @oninput="e => Sim.FiringDelay = int.Parse(e.Value!.ToString()!)"
                               style="width:100%;accent-color:#00897b;" />
                    </div>

                    @if (Sim.IsDeadlock)
                    {
                        <div style="padding:6px 8px;background:#ffebee;border-radius:7px;font-size:11px;color:#e53935;font-weight:600;margin-bottom:8px;">
                            ⚠ Deadlock — no transitions enabled.
                        </div>
                    }
                </section>

                <div class="sidebar-divider"></div>

                @* Firing history *@
                <section class="sidebar-section" style="flex:1;overflow:hidden;display:flex;flex-direction:column;">
                    <div style="display:flex;align-items:center;margin-bottom:6px;">
                        <div class="section-label" style="margin-bottom:0;flex:1;">History</div>
                        @if (Sim.IsViewingHistory)
                        {
                            <button @onclick="() => Sim.ReturnToPresent()"
                                    style="font-size:10px;font-weight:700;color:#00897b;background:#e0f5f3;border:none;border-radius:10px;padding:2px 8px;cursor:pointer;white-space:nowrap;">
                                ↩ Present (@Sim.LiveStepCount)
                            </button>
                        }
                    </div>

                    @if (Sim.IsViewingHistory)
                    {
                        <div style="font-size:10px;color:#f57f17;background:#fff8e1;border-radius:6px;padding:4px 7px;margin-bottom:6px;font-weight:600;">
                            Viewing step @Sim.StepCount — future discarded on next fire
                        </div>
                    }

                    <div style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:3px;">
                        @{
                            var displayHistory = Sim.FullHistory;
                            var currentStep = Sim.StepCount - 1;
                        }
                        @for (int i = displayHistory.Count - 1; i >= 0; i--)
                        {
                            var stepIdx = i;
                            var step = i + 1;
                            var name = Sim.GetTransitionName(displayHistory[i]);
                            var isCurrent = i == currentStep;
                            var isFuture = Sim.IsViewingHistory && i >= Sim.StepCount;
                            <button @onclick="() => Sim.JumpToStep(stepIdx)"
                                    style="display:flex;align-items:center;gap:7px;padding:4px 6px;border-radius:6px;background:@(isCurrent ? "#e0f5f3" : isFuture ? "#fafafa" : "transparent");font-size:12px;border:@(isFuture ? "1px dashed #e0e0e0" : "none");cursor:pointer;text-align:left;width:100%;opacity:@(isFuture ? "0.5" : "1");">
                                <span style="color:#ccc;font-size:10px;min-width:18px;text-align:right;">@step</span>
                                <svg viewBox="0 0 24 24" fill="@(isFuture ? "#ccc" : "#00897b")" style="width:9px;height:9px;flex-shrink:0;"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                                <span style="color:@(isCurrent ? "#00897b" : isFuture ? "#ccc" : "#555");font-weight:@(isCurrent ? "700" : "400");">@name</span>
                                @if (!isCurrent && !isFuture)
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:10px;height:10px;margin-left:auto;flex-shrink:0;">
                                        <polyline points="1 4 1 10 7 10" />
                                        <path d="M3.51 15a9 9 0 1 0 .49-4.95" />
                                    </svg>
                                }
                            </button>
                        }
                        @if (!displayHistory.Any())
                        {
                            <span style="font-size:11px;color:#ccc;padding:4px 6px;">No transitions fired yet.</span>
                        }
                    </div>
                </section>
            }
            else
            {
                @* ── Normal editing tools ── *@
                <section class="sidebar-section">
                    <div class="section-label">Tools</div>
                    <div class="tool-list">

                        <button class="tool-btn @(ActiveTool == "select" ? "active" : "")"
                                title="Select" @onclick='() => SetTool("select")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
                                <path d="M5 3l14 9-7 1-4 7z" />
                            </svg>
                        </button>

                        <button class="tool-btn @(ActiveTool == "place" ? "active" : "")"
                                title="Place" @onclick='() => SetTool("place")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="8" />
                            </svg>
                        </button>

                        <button class="tool-btn @(ActiveTool == "transition" ? "active" : "")"
                                title="Transition" @onclick='() => SetTool("transition")'>
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <rect x="8" y="3" width="8" height="18" rx="1.5" />
                            </svg>
                        </button>

                        <button class="tool-btn @(ActiveTool == "arc" ? "active" : "") @(Manager.HasPendingLink ? "pending" : "")"
                                title="Arc" @onclick='() => SetTool("arc")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="19" x2="17" y2="7" />
                                <polyline points="11,7 17,7 17,13" />
                            </svg>
                        </button>

                    </div>
                </section>
            }

            @if (!StateService.IsSimulating)
            {
                <div class="sidebar-spacer"></div>

                <div class="sidebar-divider"></div>

                <section class="sidebar-section props-section">
                    <div class="section-label">Properties</div>

                    @if (SelectedModel is PlaceNode p)
                    {
                        <div class="prop-group">
                            <div class="prop-field">
                                <label class="prop-label">Name</label>
                                <input class="prop-input" @bind-value="p.Data.Name"
                                       @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(p)" />
                            </div>
                            <div class="prop-field">
                                <label class="prop-label">Tokens</label>
                                <input class="prop-input" type="number" min="0"
                                       @bind-value="p.Data.Tokens"
                                       @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(p)" />
                            </div>
                        </div>
                    }
                    else if (SelectedModel is TransitionNode t)
                    {
                        <div class="prop-group">
                            <div class="prop-field">
                                <label class="prop-label">Name</label>
                                <input class="prop-input" @bind-value="t.Data.Name"
                                       @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(t)" />
                            </div>
                            <div class="prop-field">
                                <label class="prop-label">Priority</label>
                                <input class="prop-input" type="number" min="0"
                                       @bind-value="t.Data.Priority"
                                       @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(t)" />
                            </div>
                        </div>
                    }
                    else if (SelectedModel is PetriLinkModel arcSel)
                    {
                        var arcOnlyNormal = IsArcOnlyNormal(arcSel);
                        <div class="prop-group">
                            <div class="prop-field">
                                <label class="prop-label">Weight</label>
                                <input class="prop-input" type="number" min="1"
                                       @bind-value="arcSel.Weight"
                                       @bind-value:event="oninput" @bind-value:after="() => UpdateDiagram(arcSel)" />
                            </div>
                            <div class="prop-field">
                                <label class="prop-label">Arc type</label>
                                <div class="arc-type-btns">
                                    <button class="arc-type-btn @(arcSel.ArcType == ArcType.Normal ? "active" : "")"
                                            @onclick="() => SetArcType(arcSel, ArcType.Normal)">
                                        Normal
                                    </button>
                                    <button class="arc-type-btn @(arcSel.ArcType == ArcType.Inhibitor ? "active" : "") @(arcOnlyNormal ? "arc-type-btn-disabled" : "")"
                                            disabled="@arcOnlyNormal"
                                            title="@(arcOnlyNormal ? "Only available on Place → Transition arcs" : "")"
                                            @onclick="() => { if (!arcOnlyNormal) SetArcType(arcSel, ArcType.Inhibitor); }">
                                        Inhibit
                                    </button>
                                    <button class="arc-type-btn @(arcSel.ArcType == ArcType.Reset ? "active" : "") @(arcOnlyNormal ? "arc-type-btn-disabled" : "")"
                                            disabled="@arcOnlyNormal"
                                            title="@(arcOnlyNormal ? "Only available on Place → Transition arcs" : "")"
                                            @onclick="() => { if (!arcOnlyNormal) SetArcType(arcSel, ArcType.Reset); }">
                                        Reset
                                    </button>
                                </div>
                                @if (arcOnlyNormal)
                                {
                                    <p class="arc-type-hint">Inhibitor and Reset arcs require a Place → Transition direction.</p>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="prop-empty">No element selected.</p>
                    }

                </section>
            }

            @* Debug log — small button pinned to bottom of sidebar *@
            <div class="debug-corner">
                <button class="debug-corner-btn @(_logPanelOpen ? "active" : "")"
                        title="Toggle debug log"
                        @onclick="() => { _logPanelOpen = !_logPanelOpen; StateHasChanged(); }">
                    ◉ Debug
                </button>
                @if (_logPanelOpen)
                {
                    <div class="debug-log-panel open">
                        <div class="debug-log-header">
                            <span>@Manager.Logger.GetEntries().Count entries</span>
                            <div class="debug-log-actions">
                                <button class="debug-log-btn" @onclick="CopyLog" title="Copy to clipboard">Copy</button>
                                <button class="debug-log-btn" @onclick="ClearLog">Clear</button>
                            </div>
                        </div>
                        <div class="debug-log-body">
                            @foreach (var entry in Manager.Logger.GetEntries().Reverse())
                            {
                                <div class="debug-log-line">@entry.ToString()</div>
                            }
                        </div>
                    </div>
                }
            </div>

        </aside>

        @* ── Canvas area ── *@
        <div class="canvas-wrap">

            @* Analysis buttons — top right *@
            <div class="analysis-bar">
                <button class="analysis-btn undo-redo-btn @(!Manager.History.CanUndo ? "disabled" : "")"
                        title="Undo (Ctrl+Z)" @onclick="Undo" disabled="@(!Manager.History.CanUndo)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 14 4 9 9 4" />
                        <path d="M20 20v-7a4 4 0 0 0-4-4H4" />
                    </svg>
                    Undo
                </button>
                <button class="analysis-btn undo-redo-btn @(!Manager.History.CanRedo ? "disabled" : "")"
                        title="Redo (Ctrl+Y)" @onclick="Redo" disabled="@(!Manager.History.CanRedo)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 14 20 9 15 4" />
                        <path d="M4 20v-7a4 4 0 0 1 4-4h12" />
                    </svg>
                    Redo
                </button>
                <div class="analysis-bar-divider"></div>
                <button class="analysis-btn analysis-btn-icon @(_settingsOpen ? "active" : "")"
                        title="Settings"
                        @onclick="() => _settingsOpen = !_settingsOpen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                    </svg>
                </button>
            </div>

            @* Diagram *@
            <div id="diagram-container" tabindex="0"
                 style="--grid-size: @(GridSize)px; --grid-offset-x: @(GridOffsetX)px; --grid-offset-y: @(GridOffsetY)px; background-image: @(GridBackgroundImage)">
                <CascadingValue Value="Manager.Diagram" IsFixed="true">
                    <DiagramCanvas />
                </CascadingValue>

                @if (ActiveTool == "select")
                {
                    <div class="sel-capture-layer"></div>
                }

                @if (_selRectActive)
                {
                    var rx = Math.Min(_selStart.X, _selCurrent.X);
                    var ry = Math.Min(_selStart.Y, _selCurrent.Y);
                    var rw = Math.Abs(_selCurrent.X - _selStart.X);
                    var rh = Math.Abs(_selCurrent.Y - _selStart.Y);
                    <svg class="sel-rect-overlay">
                        <rect x="@rx" y="@ry" width="@rw" height="@rh" class="sel-rect" />
                    </svg>
                }

                @* Ghost preview shown while holding mouse during place/transition placement *@
                <div id="placement-ghost" style="display:none;pointer-events:none;position:absolute;z-index:200;"></div>
            </div>

            @* Navigator panel *@
            <div class="navigator-panel @(_navigatorOpen ? "open" : "")">
                <div class="navigator-header">
                    <span class="navigator-title">Elements</span>
                    <span class="navigator-counts">@_navPlaces.Count P &nbsp; @_navTransitions.Count T &nbsp; @_navArcs.Count A</span>
                </div>

                @{
                    var selectedSet = Manager.Diagram.GetSelectedModels().ToHashSet();
                }

                @if (_navPlaces.Any())
                {
                    <div class="nav-group-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="8" /></svg>
                        Places
                    </div>
                    @foreach (var place in _navPlaces)
                    {
                        var placeSelected = selectedSet.Contains(place);
                        <button class="nav-item @(placeSelected ? "nav-item-selected" : "")"
                                @onclick="() => FocusElement(place)">
                            <svg class="nav-item-icon nav-icon-place" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                                <circle cx="8" cy="8" r="6" />
                            </svg>
                            <span class="nav-item-name">@place.Data.Name</span>
                            @if (place.Data.Tokens > 0)
                            {
                                <span class="nav-item-badge">@place.Data.Tokens</span>
                            }
                        </button>
                    }
                }

                @if (_navTransitions.Any())
                {
                    <div class="nav-group-label">
                        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="8" y="3" width="8" height="18" rx="1.5" /></svg>
                        Transitions
                    </div>
                    @foreach (var trans in _navTransitions)
                    {
                        var transSelected = selectedSet.Contains(trans);
                        <button class="nav-item @(transSelected ? "nav-item-selected" : "")"
                                @onclick="() => FocusElement(trans)">
                            <svg class="nav-item-icon nav-icon-transition" viewBox="0 0 16 16" fill="currentColor">
                                <rect x="5" y="1" width="6" height="14" rx="1" />
                            </svg>
                            <span class="nav-item-name">@trans.Data.Name</span>
                            @if (trans.Data.Priority > 0)
                            {
                                <span class="nav-item-badge nav-badge-priority">P@(trans.Data.Priority)</span>
                            }
                        </button>
                    }
                }

                @if (_navArcs.Any())
                {
                    <div class="nav-group-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="19" x2="17" y2="7" />
                            <polyline points="11,7 17,7 17,13" />
                        </svg>
                        Arcs
                    </div>
                    @foreach (var navArc in _navArcs)
                    {
                        var arcSelected = selectedSet.Contains(navArc);
                        var arcLabel = GetArcLabel(navArc);
                        <button class="nav-item @(arcSelected ? "nav-item-selected" : "")"
                                @onclick="() => FocusArc(navArc)">
                            <svg class="nav-item-icon nav-icon-arc" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="2" y1="14" x2="12" y2="4" />
                                <polyline points="7,4 12,4 12,9" />
                            </svg>
                            <span class="nav-item-name">@arcLabel</span>
                            @if (navArc.Weight > 1)
                            {
                                <span class="nav-item-badge">w@(navArc.Weight)</span>
                            }
                            @if (navArc.ArcType != ArcType.Normal)
                            {
                                <span class="nav-item-badge nav-badge-arctype">@(navArc.ArcType.ToString().Substring(0, 1))</span>
                            }
                        </button>
                    }
                }

                @if (!_navPlaces.Any() && !_navTransitions.Any() && !_navArcs.Any())
                {
                    <p class="nav-empty">No elements yet.<br />Add places, transitions and arcs to the canvas.</p>
                }
            </div>

            <button class="navigator-toggle @(_navigatorOpen ? "active" : "")"
                    title="@(_navigatorOpen ? "Close navigator" : "Open navigator")"
                    @onclick="ToggleNavigator">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
            </button>

            @* Zoom controls — bottom right *@
            <div class="zoom-controls">
                <button class="zoom-btn" title="Zoom in" @onclick="() => Manager.ZoomIn()">+</button>
                <span class="zoom-label">@((Manager.Diagram.Zoom * 100).ToString("F0"))%</span>
                <button class="zoom-btn" title="Zoom out" @onclick="() => Manager.ZoomOut()">−</button>
                <button class="zoom-btn zoom-reset" title="Reset view" @onclick="ResetView">⌂</button>
            </div>

            @* Settings panel — top right, below analysis bar *@
            <div class="settings-panel @(_settingsOpen ? "open" : "")">
                <div class="settings-panel-header">
                    <span class="settings-panel-title">Settings</span>
                    <button class="settings-panel-reset" title="Reset to defaults" @onclick="ResetSettings">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="1 4 1 10 7 10" />
                            <path d="M3.51 15a9 9 0 1 0 .49-4.5" />
                        </svg>
                        Reset
                    </button>
                </div>
                <div class="settings-panel-body">

                    <div class="settings-group">
                        <div class="settings-group-title">Grid</div>
                        <div class="settings-row">
                            <span class="settings-row-label">Align to grid</span>
                            <label class="settings-toggle">
                                <input type="checkbox" checked="@Settings.GridEnabled"
                                       @onchange="e => ApplySetting(s => s.GridEnabled = e.Value is bool b && b)" />
                                <span class="settings-toggle-slider"></span>
                            </label>
                        </div>
                        <div class="settings-row">
                            <span class="settings-row-label">Grid size</span>
                            <div class="settings-stepper">
                                <button @onclick="() => ApplySetting(s => s.GridSize = Math.Max(5, s.GridSize - 5))">−</button>
                                <span>@((int)Settings.GridSize)</span>
                                <button @onclick="() => ApplySetting(s => s.GridSize = Math.Min(100, s.GridSize + 5))">+</button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            @* Analysis result toast *@
            @if (_analysisResult != null)
            {
                <div class="analysis-toast @(_analysisOk ? "toast-ok" : "toast-warn")">
                    <span>@_analysisResult</span>
                    <button class="toast-close" @onclick="() => _analysisResult = null">✕</button>
                </div>
            }

        </div>

        @* ── Analysis panel (docked right, collapsible / floatable) ── *@
        <AnalysisPanel />

    </div>
</div>

@code {
    private string ActiveTool = "";
    private Model? SelectedModel { get; set; }
    private string? _analysisResult;
    private bool _analysisOk;
    private bool _navigatorOpen = false;

    // Navigator cached lists — rebuilt on every structural change
    private List<PlaceNode> _navPlaces = new();
    private List<TransitionNode> _navTransitions = new();
    private List<PetriLinkModel> _navArcs = new();

    private bool _settingsOpen = false;

    private double EffectiveGridSize => Math.Max(5.0, Settings.GridSize) * Manager.Diagram.Zoom;
    private string GridSize => EffectiveGridSize.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string GridOffsetX => (Manager.Diagram.Pan.X % EffectiveGridSize).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string GridOffsetY => (Manager.Diagram.Pan.Y % EffectiveGridSize).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private string GridBackgroundImage => Settings.GridEnabled
        ? "radial-gradient(circle, #d4d4d4 1px, transparent 1px)"
        : "none";

    private DotNetObjectReference<Home>? _dotNetRef;
    private bool _jsRegistered = false;

    protected override void OnInitialized()
    {
        Manager.Diagram.PointerDown += OnPointerDown;
        Manager.Diagram.PointerUp += OnPointerUp;
        Manager.Diagram.PointerDoubleClick += OnDoubleClick;
        Manager.Diagram.KeyDown += OnKeyDown;
        Manager.Diagram.SelectionChanged += OnSelectionChanged;
        Manager.Diagram.Nodes.Removed += OnNodeRemoved;
        Manager.Diagram.Links.Removed += OnLinkRemoved;
        Manager.Diagram.Nodes.Added += OnNodeAdded;
        Manager.Diagram.Links.Added += OnLinkAdded;
        Manager.PendingLinkChanged += OnPendingLinkChanged;
        Manager.Diagram.ZoomChanged += OnZoomChanged;
        Manager.Diagram.PanChanged += OnPanChanged;
        Manager.History.HistoryChanged += OnHistoryChanged;
        Settings.Changed += OnSettingsChanged;
        StateService.OnSimulationChanged += OnSimulationStateChanged;
        Sim.OnChanged += OnSimulationStateChanged;
        RebuildNavLists();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsRegistered)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerGlobalKeyHandler", _dotNetRef);
            await JS.InvokeVoidAsync("setupPanHandlerOnce");
            _jsRegistered = true;
        }
    }

    [JSInvokable]
    public void PanByDelta(double dx, double dy)
    {
        var pan = Manager.Diagram.Pan;
        Manager.PanTo(pan.X + dx, pan.Y + dy);
    }

    [JSInvokable]
    public void OnGlobalKey(string key, bool ctrl, bool shift, bool alt)
    {
        if (key == "Escape")
        {
            HandleEscape();
            InvokeAsync(StateHasChanged);
            return;
        }
        if (ctrl && key == "z")
        {
            Manager.History.Undo();
            InvokeAsync(StateHasChanged);
            return;
        }
        if ((ctrl && key == "y") || (ctrl && shift && key == "Z"))
        {
            Manager.History.Redo();
            InvokeAsync(StateHasChanged);
            return;
        }
        if (!ctrl && (key == "Delete" || key == "Backspace"))
        {
            Manager.DeleteSelected();
            InvokeAsync(StateHasChanged);
            return;
        }
    }

    private void RebuildNavLists()
    {
        _navPlaces = Manager.Diagram.Nodes.OfType<PlaceNode>().ToList();
        _navTransitions = Manager.Diagram.Nodes.OfType<TransitionNode>().ToList();
        _navArcs = Manager.Diagram.Links
                            .OfType<PetriLinkModel>()
                            .Where(l => !l.IsDraggingEndpoint && l.Target != null)
                            .ToList();
    }

    // ── Grid / zoom / pan ─────────────────────────────────────────────────────
    private void OnZoomChanged() => InvokeAsync(StateHasChanged);
    private void OnPanChanged() => InvokeAsync(StateHasChanged);
    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    private void ApplySetting(Action<DiagramSettings> mutate)
    {
        mutate(Settings);
        Settings.NotifyChanged();
    }

    private void ResetSettings() => Settings.ResetToDefaults();

    private void Undo() { Manager.History.Undo(); StateHasChanged(); }
    private void Redo() { Manager.History.Redo(); StateHasChanged(); }
    private void ResetView() { Manager.ResetView(); StateHasChanged(); }
    private void ToggleNavigator() { _navigatorOpen = !_navigatorOpen; StateHasChanged(); }

    // ── Selection ─────────────────────────────────────────────────────────────
    private void OnSelectionChanged(SelectableModel _)
    {
        FlushPendingEdit();
        var selected = Manager.Diagram.GetSelectedModels().ToList();
        SelectedModel = selected.Count == 1 ? selected[0] : null;
        SnapshotSelected();
        InvokeAsync(StateHasChanged);
    }

    // ── Structure changes → rebuild navigator lists ───────────────────────────
    private void OnStructureChanged()
    {
        RebuildNavLists();
        InvokeAsync(StateHasChanged);
    }

    private void OnNodeAdded(NodeModel _) => OnStructureChanged();
    private void OnLinkAdded(BaseLinkModel _) => OnStructureChanged();
    private void OnNodeRemoved(NodeModel model)
    {
        if (SelectedModel == model) SelectedModel = null;
        OnStructureChanged();
    }
    private void OnLinkRemoved(BaseLinkModel model)
    {
        if (SelectedModel == model) SelectedModel = null;
        OnStructureChanged();
    }
    private void OnPendingLinkChanged() => OnStructureChanged();
    private void OnHistoryChanged() => OnStructureChanged();

    // ── Property-edit snapshots ───────────────────────────────────────────────
    private string? _snapPlaceName;
    private int _snapPlaceTokens;
    private string? _snapTransName;
    private int _snapTransPriority;
    private int _snapLinkWeight;
    private ArcType _snapLinkArcType;

    private void SnapshotSelected()
    {
        switch (SelectedModel)
        {
            case PlaceNode pn:
                _snapPlaceName = pn.Data.Name;
                _snapPlaceTokens = pn.Data.Tokens;
                break;
            case TransitionNode tn:
                _snapTransName = tn.Data.Name;
                _snapTransPriority = tn.Data.Priority;
                break;
            case PetriLinkModel ln:
                _snapLinkWeight = ln.Weight;
                _snapLinkArcType = ln.ArcType;
                break;
        }
    }

    private void FlushPendingEdit()
    {
        if (Manager.History.IsBusy) return;
        switch (SelectedModel)
        {
            case PlaceNode pn when _snapPlaceName != null:
                if (pn.Data.Name != _snapPlaceName || pn.Data.Tokens != _snapPlaceTokens)
                    Manager.History.Record(new EditPlaceCommand(pn, _snapPlaceName, _snapPlaceTokens, pn.Data.Name, pn.Data.Tokens));
                break;
            case TransitionNode tn when _snapTransName != null:
                if (tn.Data.Name != _snapTransName || tn.Data.Priority != _snapTransPriority)
                    Manager.History.Record(new EditTransitionCommand(tn, _snapTransName, _snapTransPriority, tn.Data.Name, tn.Data.Priority));
                break;
            case PetriLinkModel ln:
                if (ln.Weight != _snapLinkWeight || ln.ArcType != _snapLinkArcType)
                    Manager.History.Record(new EditLinkCommand(ln, _snapLinkWeight, _snapLinkArcType, ln.Weight, ln.ArcType));
                break;
        }
        _snapPlaceName = null;
        _snapTransName = null;
    }

    // ── Tools ─────────────────────────────────────────────────────────────────
    private void SetTool(string tool)
    {
        ActiveTool = ActiveTool == tool ? "" : tool;
        StateService.SelectTool(ActiveTool == "arc"
            ? DiagramStateService.ToolType.Arc
            : DiagramStateService.ToolType.Select);
        if (ActiveTool == "arc") Manager.EnableLinkDrawing();
        else Manager.DisableLinkDrawing();
        _ = JS.InvokeVoidAsync("setSelectToolActive", ActiveTool == "select");
    }


    private void SetArcType(PetriLinkModel link, ArcType type)
    {
        if (link.ArcType == type) return;
        FlushPendingEdit();
        link.ArcType = type;
        link.Refresh();
        Manager.History.Record(new EditLinkCommand(link, _snapLinkWeight, _snapLinkArcType, link.Weight, link.ArcType));
        SnapshotSelected();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateDiagram(Model? model = null)
    {
        SyncRenderedText(model);
        if (model is NodeModel node) node.Refresh();
        else if (model is PetriLinkModel lnk) lnk.Refresh();
        InvokeAsync(StateHasChanged);
    }

    private void SyncRenderedText(Model? model)
    {
        if (model is PlaceNode pn) pn.Title = pn.Data.Name;
        else if (model is TransitionNode tn) tn.Title = tn.Data.Name;
    }

    // ── Pointer / keyboard ────────────────────────────────────────────────────

    private string? _pendingAction;
    private Model? _pendingModel;
    private Point? _pendingPoint;

    [JSInvokable]
    public void OnCanvasPointerUp()
    {
        if (_selRectArmed)
        {
            if (_selRectActive) CommitSelectionRect();
            CancelSelRect();
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnPointerDown(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button != 0) return;
        if (StateService.IsSimulating) return;

        // Only intercept placement and arc tools.
        // Select tool (and no-tool) let Blazor.Diagrams handle everything
        // natively — it manages selection, drag, and multi-select on its own.
        if (ActiveTool is "place" or "transition" or "arc")
        {
            _pendingAction = ActiveTool;
            _pendingModel = model;
            _pendingPoint = new Point(e.ClientX, e.ClientY);

            // Show placement ghost while button is held
            if (ActiveTool is "place" or "transition")
            {
                double placeSize = Settings.PlaceSize > 0 ? Settings.PlaceSize : 60;
                double transW = Settings.TransitionWidth > 0 ? Settings.TransitionWidth : 36;
                double transH = Settings.TransitionHeight > 0 ? Settings.TransitionHeight : 72;
                double nodeW = (ActiveTool == "place" ? placeSize : transW) * Manager.Diagram.Zoom;
                double nodeH = (ActiveTool == "place" ? placeSize : transH) * Manager.Diagram.Zoom;
                _ = JS.InvokeVoidAsync("ghostStart", ActiveTool, EffectiveGridSize,
                    Settings.GridEnabled, nodeW, nodeH, e.ClientX, e.ClientY);
            }
        }
    }

    [JSInvokable]
    public void OnSelRectArmed(double offsetX, double offsetY)
    {
        _selRectArmed = true;
        _selRectActive = false;
        _selStart = (offsetX, offsetY);
        _selCurrent = (offsetX, offsetY);
    }

    private void OnPointerUp(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button != 0) return;

        if (_pendingAction == null) return;
        var action = _pendingAction;
        var downPt = _pendingPoint!;
        _pendingAction = null;
        _pendingModel = null;
        _pendingPoint = null;

        // Always hide ghost on release
        if (action is "place" or "transition")
            _ = JS.InvokeVoidAsync("ghostStop");

        if (action == "arc")
        {
            Manager.HandleArcToolClick(model, downPt);
            StateHasChanged();
        }
        else if (model == null && action is "place" or "transition")
        {
            Manager.AddNodeAt(action, new Point(e.ClientX, e.ClientY));
            StateHasChanged();
        }
    }

    private void OnDoubleClick(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        Manager.HandleDoubleClick(model, new Point(e.ClientX, e.ClientY));
        StateHasChanged();
    }

    private void OnKeyDown(Blazor.Diagrams.Core.Events.KeyboardEventArgs e)
    {
        if (e.Key == "+" || e.Key == "=") { Manager.ZoomIn(); InvokeAsync(StateHasChanged); }
        if (e.Key == "-") { Manager.ZoomOut(); InvokeAsync(StateHasChanged); }
    }

    private void HandleEscape()
    {
        // Hide ghost if placement was in progress
        if (_pendingAction is "place" or "transition")
            _ = JS.InvokeVoidAsync("ghostStop");
        _pendingAction = null;
        _pendingModel = null;
        _pendingPoint = null;
        Manager.CancelPendingLink();
        CancelSelRect();
        Manager.Diagram.UnselectAll();
        if (ActiveTool != "")
        {
            ActiveTool = "";
            StateService.SelectTool(DiagramStateService.ToolType.Select);
            Manager.DisableLinkDrawing();
            _ = JS.InvokeVoidAsync("setSelectToolActive", false);
        }
        if (_navigatorOpen) _navigatorOpen = false;
    }

    // ── Selection rectangle ───────────────────────────────────────────────────
    private bool _selRectActive = false;
    private bool _selRectArmed = false;
    private (double X, double Y) _selStart = default;
    private (double X, double Y) _selCurrent = default;
    private const double SelRectMinDrag = 4.0;

    private void CancelSelRect()
    {
        _selRectArmed = false;
        _selRectActive = false;
    }

    [JSInvokable]
    public void OnSelPointerMoveJS(double offsetX, double offsetY)
    {
        if (!_selRectArmed) return;
        _selCurrent = (offsetX, offsetY);
        var dx = Math.Abs(_selCurrent.X - _selStart.X);
        var dy = Math.Abs(_selCurrent.Y - _selStart.Y);
        if (!_selRectActive && (dx > SelRectMinDrag || dy > SelRectMinDrag))
        {
            Manager.Diagram.UnselectAll();
            _selRectActive = true;
        }
        if (_selRectActive) InvokeAsync(StateHasChanged);
    }

    private void CommitSelectionRect()
    {
        var zoom = Manager.Diagram.Zoom;
        var pan = Manager.Diagram.Pan;

        double sx = Math.Min(_selStart.X, _selCurrent.X);
        double sy = Math.Min(_selStart.Y, _selCurrent.Y);
        double ex = Math.Max(_selStart.X, _selCurrent.X);
        double ey = Math.Max(_selStart.Y, _selCurrent.Y);

        double dsx = (sx - pan.X) / zoom;
        double dsy = (sy - pan.Y) / zoom;
        double dex = (ex - pan.X) / zoom;
        double dey = (ey - pan.Y) / zoom;

        Manager.Diagram.UnselectAll();

        foreach (var node in Manager.Diagram.Nodes)
        {
            if (node.Position == null || node.Size == null) continue;
            var nx = node.Position.X;
            var ny = node.Position.Y;
            var nw = node.Size.Width;
            var nh = node.Size.Height;
            if (nx < dex && nx + nw > dsx && ny < dey && ny + nh > dsy)
                Manager.Diagram.SelectModel(node, false);
        }

        StateHasChanged();
    }

    // ── Navigator ─────────────────────────────────────────────────────────────
    private void FocusElement(NodeModel node)
    {
        if (node.Position == null || node.Size == null) return;
        var cx = node.Position.X + node.Size.Width / 2.0;
        var cy = node.Position.Y + node.Size.Height / 2.0;
        FocusDiagramPoint(cx, cy);
        Manager.Diagram.SelectModel(node, true);
        StateHasChanged();
    }

    private void FocusArc(PetriLinkModel arc)
    {
        var src = GetArcSourceNode(arc);
        var tgt = GetArcTargetNode(arc);
        if (src?.Position == null || tgt?.Position == null) return;
        var sx = src.Position.X + (src.Size?.Width ?? 0) / 2.0;
        var sy = src.Position.Y + (src.Size?.Height ?? 0) / 2.0;
        var tx = tgt.Position.X + (tgt.Size?.Width ?? 0) / 2.0;
        var ty = tgt.Position.Y + (tgt.Size?.Height ?? 0) / 2.0;
        FocusDiagramPoint((sx + tx) / 2.0, (sy + ty) / 2.0);
        Manager.Diagram.SelectModel(arc, true);
        StateHasChanged();
    }

    private void FocusDiagramPoint(double diagramX, double diagramY)
    {
        var zoom = Manager.Diagram.Zoom;
        var container = Manager.Diagram.Container;
        var halfW = (container != null ? container.Width : 1200.0) / 2.0;
        var halfH = (container != null ? container.Height : 800.0) / 2.0;
        Manager.Diagram.SetPan(halfW - diagramX * zoom, halfH - diagramY * zoom);
    }

    private string GetArcLabel(PetriLinkModel arc)
    {
        var src = GetArcSourceNode(arc)?.Title ?? "?";
        var tgt = GetArcTargetNode(arc)?.Title ?? "?";
        return src + " \u2192 " + tgt;
    }

    private bool IsArcOnlyNormal(PetriLinkModel arc)
        => GetArcSourceNode(arc) is TransitionNode;

    private NodeModel? GetArcSourceNode(PetriLinkModel arc) => arc.Source?.Model switch
    {
        NodeModel n => n,
        PortModel pm => pm.Parent,
        _ => null
    };

    private NodeModel? GetArcTargetNode(PetriLinkModel arc) => arc.Target?.Model switch
    {
        NodeModel n => n,
        PortModel pm => pm.Parent,
        _ => null
    };

    private bool _logPanelOpen = false;

    private async Task CopyLog()
    {
        var text = string.Join("\n", Manager.Logger.GetEntries().Select(e => e.ToString()));
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private void ClearLog()
    {
        Manager.Logger.Clear();
        StateHasChanged();
    }

    // ── Analysis ──────────────────────────────────────────────────────────────
    private void ShowResult(string msg, bool ok) { _analysisResult = msg; _analysisOk = ok; StateHasChanged(); }

    // ── Simulation ────────────────────────────────────────────────────────────
    private void OnSimulationStateChanged() => InvokeAsync(StateHasChanged);

    private void StopSimulation() => Sim.Stop();
    private void ResetSimulation() => Sim.Reset();
    private void StepOnce() => Sim.StepAuto();

    // ── Dispose ───────────────────────────────────────────────────────────────
    public void Dispose()
    {
        FlushPendingEdit();
        Manager.Diagram.PointerDown -= OnPointerDown;
        Manager.Diagram.PointerUp -= OnPointerUp;
        Manager.Diagram.PointerDoubleClick -= OnDoubleClick;
        Manager.Diagram.KeyDown -= OnKeyDown;
        Manager.Diagram.SelectionChanged -= OnSelectionChanged;
        Manager.Diagram.Nodes.Removed -= OnNodeRemoved;
        Manager.Diagram.Links.Removed -= OnLinkRemoved;
        Manager.Diagram.Nodes.Added -= OnNodeAdded;
        Manager.Diagram.Links.Added -= OnLinkAdded;
        Manager.PendingLinkChanged -= OnPendingLinkChanged;
        Manager.Diagram.ZoomChanged -= OnZoomChanged;
        Manager.Diagram.PanChanged -= OnPanChanged;
        Manager.History.HistoryChanged -= OnHistoryChanged;
        Settings.Changed -= OnSettingsChanged;
        StateService.OnSimulationChanged -= OnSimulationStateChanged;
        Sim.OnChanged -= OnSimulationStateChanged;
        _ = JS.InvokeVoidAsync("unregisterGlobalKeyHandler");
        _dotNetRef?.Dispose();
    }
}
